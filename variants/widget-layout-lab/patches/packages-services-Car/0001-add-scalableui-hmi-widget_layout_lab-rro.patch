diff --git a/car_product/scalableui_hmi_widget_layout_lab/rro/CarSystemUIScalableUiHmiWidgetLayoutLabRRO/res/xml/app_panel.xml b/car_product/scalableui_hmi_widget_layout_lab/rro/CarSystemUIScalableUiHmiWidgetLayoutLabRRO/res/xml/app_panel.xml
