@@ -0,0 +1,29 @@
+<?xml version="1.0" encoding="utf-8"?>
+<Panel id="app_panel" defaultVariant="@id/closed" role="@string/default_config" displayId="0">
+    <Variant id="@+id/opened">
+        <Layer layer="@integer/app_panel_layer"/>
+        <Visibility isVisible="true"/>
+        <Bounds left="0" top="0" right="100%" bottom="100%"/>
+    </Variant>
+    <Variant id="@+id/closed">
+        <Layer layer="@integer/app_panel_layer"/>
+        <Visibility isVisible="false"/>
+        <Bounds left="0" top="100%" right="100%" bottom="200%"/>
+    </Variant>
+    <Transitions>
+        <Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=app_panel" toVariant="@id/opened"/>
+        <Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=panel_app_grid" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=lab_background_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_a_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_b_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_c_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_d_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_e_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_f_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_drop_zone_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_menu_button_panel" toVariant="@id/closed"/>
+<Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=widget_picker_panel" toVariant="@id/closed"/>
+        <Transition onEvent="_System_OnHomeEvent" toVariant="@id/closed"/>
+        <Transition onEvent="_System_TaskCloseEvent" onEventTokens="panelId=app_panel" toVariant="@id/closed"/>
+    </Transitions>
+</Panel>

