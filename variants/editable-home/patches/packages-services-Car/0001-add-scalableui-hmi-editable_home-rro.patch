diff --git a/car_product/scalableui_hmi_editable_home/rro/CarSystemUIScalableUiHmiEditableHomeRRO/res/xml/app_panel.xml b/car_product/scalableui_hmi_editable_home/rro/CarSystemUIScalableUiHmiEditableHomeRRO/res/xml/app_panel.xml
