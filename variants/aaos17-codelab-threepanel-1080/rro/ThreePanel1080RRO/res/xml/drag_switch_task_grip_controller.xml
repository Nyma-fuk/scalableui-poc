<Controller id="grip_bar_controller">
    <ControllerName>com.android.systemui.car.wm.scalableui.view.GripBarViewController</ControllerName>
    <View>com.android.systemui.car.wm.scalableui.view.HorizontalGripBar</View>
    <EventId>_User_DragEvent_split</EventId>
    <Orientation>0</Orientation>
    <SnapThreadhold>5</SnapThreadhold>
    <BreakPoints>
        <BreakPoint point="@dimen/top_breakpoint" eventId="_Drag_TaskSwitchEvent_top" />
        <BreakPoint point="@dimen/bottom_breakpoint" eventId="_Drag_TaskSwitchEvent_bottom" />
    </BreakPoints>
</Controller>
