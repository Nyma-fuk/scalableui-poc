+package com.android.car.carlauncher;
+
+import android.app.Activity;
+import android.content.ComponentName;
+import android.content.Intent;
+import android.content.pm.PackageManager;
+import android.content.pm.ResolveInfo;
+import android.graphics.Color;
+import android.graphics.Typeface;
+import android.graphics.drawable.Drawable;
+import android.os.Bundle;
+import android.view.Gravity;
+import android.view.View;
+import android.widget.ImageView;
+import android.widget.LinearLayout;
+import android.widget.ScrollView;
+import android.widget.TextView;
+
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.Comparator;
+import java.util.List;
+
+/** Picker shown in its own ScalableUI panel for assigning an app to the user slot. */
+public final class AppPickerActivity extends Activity {
+    private final List<AppEntry> mApps = new ArrayList<>();
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        loadApps();
+        setContentView(createContentView());
+    }
+
+    private void loadApps() {
+        PackageManager packageManager = getPackageManager();
+        Intent launcherIntent = new Intent(Intent.ACTION_MAIN);
+        launcherIntent.addCategory(Intent.CATEGORY_LAUNCHER);
+        List<ResolveInfo> resolvedApps = packageManager.queryIntentActivities(launcherIntent, 0);
+        for (ResolveInfo resolveInfo : resolvedApps) {
+            if (resolveInfo.activityInfo == null
+                    || getPackageName().equals(resolveInfo.activityInfo.packageName)) {
+                continue;
+            }
+            ComponentName componentName = new ComponentName(resolveInfo.activityInfo.packageName,
+                    resolveInfo.activityInfo.name);
+            CharSequence label = resolveInfo.loadLabel(packageManager);
+            Drawable icon = resolveInfo.loadIcon(packageManager);
+            mApps.add(new AppEntry(label == null ? componentName.flattenToShortString()
+                    : label.toString(), componentName, icon));
+        }
+        Collections.sort(mApps, Comparator.comparing(entry -> entry.label.toLowerCase()));
+    }
+
+    private View createContentView() {
+        LinearLayout root = new LinearLayout(this);
+        root.setOrientation(LinearLayout.VERTICAL);
+        root.setPadding(dp(28), dp(24), dp(28), dp(20));
+        root.setBackgroundColor(Color.rgb(18, 20, 24));
+
+        TextView title = new TextView(this);
+        title.setText(R.string.app_picker_title);
+        title.setTextColor(Color.WHITE);
+        title.setTextSize(24);
+        title.setTypeface(Typeface.DEFAULT_BOLD);
+        root.addView(title, new LinearLayout.LayoutParams(
+                LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT));
+
+        TextView subtitle = new TextView(this);
+        subtitle.setText(R.string.app_picker_message);
+        subtitle.setTextColor(Color.rgb(190, 196, 204));
+        subtitle.setTextSize(14);
+        subtitle.setPadding(0, dp(4), 0, dp(14));
+        root.addView(subtitle, new LinearLayout.LayoutParams(
+                LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT));
+
+        ScrollView scrollView = new ScrollView(this);
+        LinearLayout list = new LinearLayout(this);
+        list.setOrientation(LinearLayout.VERTICAL);
+        scrollView.addView(list, new ScrollView.LayoutParams(
+                ScrollView.LayoutParams.MATCH_PARENT, ScrollView.LayoutParams.WRAP_CONTENT));
+
+        for (AppEntry appEntry : mApps) {
+            list.addView(createRow(appEntry));
+        }
+
+        root.addView(scrollView, new LinearLayout.LayoutParams(
+                LinearLayout.LayoutParams.MATCH_PARENT, 0, 1));
+        return root;
+    }
+
+    private View createRow(AppEntry appEntry) {
+        LinearLayout row = new LinearLayout(this);
+        row.setGravity(Gravity.CENTER_VERTICAL);
+        row.setPadding(dp(14), dp(10), dp(14), dp(10));
+        row.setMinimumHeight(dp(72));
+        row.setBackgroundColor(Color.rgb(32, 36, 42));
+        row.setOnClickListener(view -> selectApp(appEntry.componentName));
+
+        ImageView icon = new ImageView(this);
+        icon.setImageDrawable(appEntry.icon);
+        row.addView(icon, new LinearLayout.LayoutParams(dp(44), dp(44)));
+
+        TextView label = new TextView(this);
+        label.setText(appEntry.label);
+        label.setTextColor(Color.WHITE);
+        label.setTextSize(18);
+        label.setSingleLine(true);
+        label.setPadding(dp(14), 0, 0, 0);
+        row.addView(label, new LinearLayout.LayoutParams(0,
+                LinearLayout.LayoutParams.WRAP_CONTENT, 1));
+
+        LinearLayout.LayoutParams params = new LinearLayout.LayoutParams(
+                LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
+        params.setMargins(0, 0, 0, dp(8));
+        row.setLayoutParams(params);
+        return row;
+    }
+
+    private void selectApp(ComponentName componentName) {
+        PanelAssignmentStore.setSelectedUserSlotComponent(this, componentName);
+        Intent intent = new Intent(PanelAssignmentStore.ACTION_USER_SLOT_ASSIGNED);
+        intent.setPackage(getPackageName());
+        sendBroadcast(intent);
+        finish();
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+
+    private static final class AppEntry {
+        final String label;
+        final ComponentName componentName;
+        final Drawable icon;
+
+        AppEntry(String label, ComponentName componentName, Drawable icon) {
+            this.label = label;
+            this.componentName = componentName;
+            this.icon = icon;
+        }
+    }
+}
