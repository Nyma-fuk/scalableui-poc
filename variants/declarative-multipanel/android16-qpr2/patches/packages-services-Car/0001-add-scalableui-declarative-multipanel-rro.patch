+package com.android.car.carlauncher;
+
+import android.app.Activity;
+import android.content.BroadcastReceiver;
+import android.content.ComponentName;
+import android.content.Context;
+import android.content.Intent;
+import android.content.IntentFilter;
+import android.os.Bundle;
+import android.view.View;
+
+/** Empty customizable workspace slot. */
+public final class EmptySlotActivity extends Activity {
+    private final BroadcastReceiver mAssignmentReceiver = new BroadcastReceiver() {
+        @Override
+        public void onReceive(Context context, Intent intent) {
+            launchSelectedAppIfAvailable();
+        }
+    };
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        registerReceiver(mAssignmentReceiver,
+                new IntentFilter(PanelAssignmentStore.ACTION_USER_SLOT_ASSIGNED),
+                Context.RECEIVER_NOT_EXPORTED);
+        if (launchSelectedAppIfAvailable()) {
+            return;
+        }
+        View view = StubViews.createMessageView(this,
+                getString(R.string.empty_slot_title),
+                getString(R.string.empty_slot_message),
+                getString(R.string.empty_slot_button),
+                this::openPicker);
+        setContentView(view);
+    }
+
+    @Override
+    protected void onDestroy() {
+        unregisterReceiver(mAssignmentReceiver);
+        super.onDestroy();
+    }
+
+    private boolean launchSelectedAppIfAvailable() {
+        ComponentName selectedComponent = PanelAssignmentStore.getSelectedUserSlotComponent(this);
+        if (selectedComponent == null) {
+            return false;
+        }
+        View view = StubViews.createMessageView(this,
+                getString(R.string.empty_slot_launching_title),
+                selectedComponent.flattenToShortString(),
+                null,
+                null);
+        setContentView(view);
+        view.post(() -> PanelAssignmentStore.launchInUserSlot(this, selectedComponent));
+        return true;
+    }
+
+    private void openPicker() {
+        Intent intent = new Intent(PanelAssignmentStore.ACTION_SHOW_PANEL);
+        intent.setPackage(getPackageName());
+        intent.setClassName(getPackageName(), PanelTriggerActivity.class.getName());
+        intent.setData(PanelAssignmentStore.createTargetPanelUri(
+                PanelAssignmentStore.PANEL_APP_PICKER));
+        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
+        intent.putExtra(PanelAssignmentStore.EXTRA_TARGET_PANEL_ID,
+                PanelAssignmentStore.PANEL_APP_PICKER);
+        intent.putExtra(PanelAssignmentStore.EXTRA_ASSIGN_PANEL_ID,
+                PanelAssignmentStore.PANEL_USER_SLOT);
+        startActivity(intent);
+    }
+}
