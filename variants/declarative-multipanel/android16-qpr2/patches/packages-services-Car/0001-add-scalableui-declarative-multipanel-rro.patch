+package com.android.car.carlauncher;
+
+import android.app.Activity;
+import android.content.Intent;
+import android.os.Bundle;
+import android.view.View;
+
+/** Empty customizable workspace slot. */
+public final class EmptySlotActivity extends Activity {
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        View view = StubViews.createMessageView(this,
+                getString(R.string.empty_slot_title),
+                getString(R.string.empty_slot_message),
+                getString(R.string.empty_slot_button),
+                this::openPicker);
+        setContentView(view);
+    }
+
+    private void openPicker() {
+        Intent intent = new Intent("com.android.car.carlauncher.ACTION_APP_GRID");
+        intent.setPackage(getPackageName());
+        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK);
