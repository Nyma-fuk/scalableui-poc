+<TaskPanel id="app_panel" defaultVariant="@id/closed" role="@string/default_panel_role" displayId="0">
+    <Variant id="@+id/opened">
+        <Layer layer="30"/>
+        <Visibility isVisible="true"/>
+        <Alpha alpha="1.0"/>
+        <Corner radius="@dimen/panel_corner_radius"/>
+        <Bounds left="2%" top="5%" right="98%" bottom="95%"/>
+        <Focus onTransition="true"/>
+    </Variant>
+    <Variant id="@+id/closed">
+        <Layer layer="30"/>
+        <Visibility isVisible="false"/>
+        <Alpha alpha="1.0"/>
+        <Corner radius="@dimen/panel_corner_radius"/>
+        <Bounds left="100%" top="5%" right="158%" bottom="95%"/>
+        <Focus onTransition="false"/>
+    </Variant>
+    <Transitions>
+        <Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=app_panel" toVariant="@id/opened" duration="450" interpolator="@android:anim/overshoot_interpolator"/>
+        <Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=panel_app_grid" toVariant="@id/closed" duration="220" interpolator="@android:anim/accelerate_interpolator"/>
+        <Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=app_picker_panel" toVariant="@id/closed" duration="220" interpolator="@android:anim/accelerate_interpolator"/>
+        <Transition onEvent="_System_TaskOpenEvent" onEventTokens="panelId=user_slot_panel" toVariant="@id/closed" duration="220" interpolator="@android:anim/accelerate_interpolator"/>
+        <Transition onEvent="enter_camera_override" toVariant="@id/closed" duration="120" interpolator="@android:anim/accelerate_interpolator"/>
+        <Transition onEvent="exit_camera_override" toVariant="@id/closed" duration="120" interpolator="@android:anim/accelerate_interpolator"/>
+        <Transition onEvent="_System_OnHomeEvent" toVariant="@id/closed" duration="300" interpolator="@android:anim/accelerate_interpolator"/>
+    </Transitions>
+</TaskPanel>
