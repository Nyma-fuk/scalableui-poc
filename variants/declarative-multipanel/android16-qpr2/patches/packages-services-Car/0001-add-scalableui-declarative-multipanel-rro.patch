+package com.android.car.carlauncher;
+
+import android.app.Activity;
+import android.content.ComponentName;
+import android.content.Intent;
+import android.content.pm.ActivityInfo;
+import android.content.pm.PackageManager;
+import android.content.pm.ResolveInfo;
+import android.graphics.Color;
+import android.os.Bundle;
+import android.view.Gravity;
+import android.view.View;
+import android.widget.LinearLayout;
+import android.widget.ScrollView;
+import android.widget.TextView;
+
+import java.util.Collections;
+import java.util.List;
+
+/** Minimal app grid kept under the original CarLauncher package for system bar compatibility. */
+public final class AppGridActivity extends Activity {
+    static final String EXTRA_TARGET_PANEL_ID =
+            "com.android.car.scalableui.extra.TARGET_PANEL_ID";
+
+    private static final int CONTENT_PADDING_DP = 32;
+    private static final int ROW_PADDING_DP = 18;
+    private String mTargetPanelId;
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        mTargetPanelId = getIntent().getStringExtra(EXTRA_TARGET_PANEL_ID);
+        setContentView(createAppGrid());
+    }
+
+    private View createAppGrid() {
+        LinearLayout content = new LinearLayout(this);
+        content.setOrientation(LinearLayout.VERTICAL);
+        content.setPadding(dp(CONTENT_PADDING_DP), dp(CONTENT_PADDING_DP),
+                dp(CONTENT_PADDING_DP), dp(CONTENT_PADDING_DP));
+        content.setBackgroundColor(getColor(R.color.stub_background));
+
+        TextView title = new TextView(this);
+        title.setText(mTargetPanelId == null
+                ? getString(R.string.app_grid_title)
+                : getString(R.string.app_grid_assign_title));
+        title.setTextColor(getColor(R.color.stub_on_surface));
+        title.setTextSize(32);
+        title.setGravity(Gravity.CENTER_VERTICAL);
+        content.addView(title, new LinearLayout.LayoutParams(
+                LinearLayout.LayoutParams.MATCH_PARENT, dp(64)));
+
+        if (mTargetPanelId != null) {
+            TextView subtitle = new TextView(this);
+            subtitle.setText(getString(R.string.app_grid_assign_message, mTargetPanelId));
+            subtitle.setTextColor(getColor(R.color.stub_on_surface_variant));
+            subtitle.setTextSize(16);
+            content.addView(subtitle, new LinearLayout.LayoutParams(
+                    LinearLayout.LayoutParams.MATCH_PARENT, dp(48)));
+        }
+
+        List<ResolveInfo> apps = getLaunchableApps();
+        for (ResolveInfo app : apps) {
+            content.addView(createAppRow(app));
+        }
+
+        ScrollView scrollView = new ScrollView(this);
+        scrollView.setFillViewport(true);
+        scrollView.addView(content);
+        return scrollView;
+    }
+
+    private List<ResolveInfo> getLaunchableApps() {
+        Intent queryIntent = new Intent(Intent.ACTION_MAIN);
+        queryIntent.addCategory(Intent.CATEGORY_LAUNCHER);
+        PackageManager packageManager = getPackageManager();
+        List<ResolveInfo> apps = packageManager.queryIntentActivities(queryIntent, 0);
+        Collections.sort(apps, new ResolveInfo.DisplayNameComparator(packageManager));
+        return apps;
+    }
+
+    private View createAppRow(ResolveInfo app) {
+        PackageManager packageManager = getPackageManager();
+        ActivityInfo activityInfo = app.activityInfo;
+        String label = String.valueOf(app.loadLabel(packageManager));
+        String component = activityInfo.packageName + "/" + activityInfo.name;
+
+        LinearLayout row = new LinearLayout(this);
+        row.setOrientation(LinearLayout.VERTICAL);
+        row.setGravity(Gravity.CENTER_VERTICAL);
+        row.setPadding(dp(ROW_PADDING_DP), dp(12), dp(ROW_PADDING_DP), dp(12));
+        row.setBackgroundColor(getColor(R.color.stub_surface));
+
+        TextView title = new TextView(this);
+        title.setText(label);
+        title.setTextColor(getColor(R.color.stub_on_surface));
+        title.setTextSize(22);
+        row.addView(title);
+
+        TextView subtitle = new TextView(this);
+        subtitle.setText(component);
+        subtitle.setTextColor(getColor(R.color.stub_on_surface_variant));
+        subtitle.setTextSize(13);
+        row.addView(subtitle);
+
+        row.setOnClickListener(v -> launchApp(activityInfo));
+
+        LinearLayout.LayoutParams params = new LinearLayout.LayoutParams(
+                LinearLayout.LayoutParams.MATCH_PARENT, LinearLayout.LayoutParams.WRAP_CONTENT);
+        params.setMargins(0, dp(10), 0, 0);
+        row.setLayoutParams(params);
+        return row;
+    }
+
+    private void launchApp(ActivityInfo activityInfo) {
+        ComponentName componentName = new ComponentName(activityInfo.packageName, activityInfo.name);
+        Intent launchIntent = Intent.makeMainActivity(componentName);
+        launchIntent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK
+                | Intent.FLAG_ACTIVITY_RESET_TASK_IF_NEEDED
+                | Intent.FLAG_ACTIVITY_CLEAR_TOP
+                | Intent.FLAG_ACTIVITY_SINGLE_TOP);
+        if (mTargetPanelId != null) {
+            launchIntent.putExtra(EXTRA_TARGET_PANEL_ID, mTargetPanelId);
+        }
+        startActivity(launchIntent);
+        finishAndRemoveTask();
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+}
