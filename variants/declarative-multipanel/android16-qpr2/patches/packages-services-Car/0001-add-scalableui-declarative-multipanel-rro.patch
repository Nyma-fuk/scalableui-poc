+ * limitations under the License.
+ */
+
+package com.android.car.carlauncher;
+
+import android.content.ComponentName;
+import android.content.Context;
+import android.content.Intent;
+import android.content.SharedPreferences;
+import android.content.pm.PackageManager;
+import android.net.Uri;
+
+/** Stores the demo assignment from the picker panel to the customizable panel. */
+final class PanelAssignmentStore {
+    static final String ACTION_APP_PICKER = "com.android.car.carlauncher.ACTION_APP_PICKER";
+    static final String ACTION_SHOW_PANEL = "com.android.car.carlauncher.ACTION_SHOW_PANEL";
+    static final String ACTION_USER_SLOT_ASSIGNED =
+            "com.android.car.carlauncher.ACTION_USER_SLOT_ASSIGNED";
+    static final String EXTRA_ASSIGN_PANEL_ID =
+            "com.android.car.scalableui.extra.ASSIGN_PANEL_ID";
+    static final String EXTRA_TARGET_PANEL_ID =
+            "com.android.car.scalableui.extra.TARGET_PANEL_ID";
+    static final String PANEL_APP_PICKER = "app_picker_panel";
+    static final String PANEL_USER_SLOT = "user_slot_panel";
+
+    private static final String PREFS = "scalableui_panel_assignments";
+    private static final String KEY_USER_SLOT_COMPONENT = "user_slot_component";
+
+    private PanelAssignmentStore() {}
+
+    static void setSelectedUserSlotComponent(Context context, ComponentName componentName) {
+        context.getSharedPreferences(PREFS, Context.MODE_PRIVATE)
+                .edit()
+                .putString(KEY_USER_SLOT_COMPONENT, componentName.flattenToString())
+                .apply();
+    }
+
+    static ComponentName getSelectedUserSlotComponent(Context context) {
+        String value = context.getSharedPreferences(PREFS, Context.MODE_PRIVATE)
+                .getString(KEY_USER_SLOT_COMPONENT, null);
+        if (value == null) {
+            return null;
+        }
+        ComponentName componentName = ComponentName.unflattenFromString(value);
+        if (componentName == null || !isLaunchable(context, componentName)) {
+            clearSelectedUserSlotComponent(context);
+            return null;
+        }
+        return componentName;
+    }
+
+    static void clearSelectedUserSlotComponent(Context context) {
+        context.getSharedPreferences(PREFS, Context.MODE_PRIVATE)
+                .edit()
+                .remove(KEY_USER_SLOT_COMPONENT)
+                .apply();
+    }
+
+    static void launchInUserSlot(Context context, ComponentName componentName) {
+        Intent intent = new Intent(Intent.ACTION_MAIN);
+        intent.addCategory(Intent.CATEGORY_LAUNCHER);
+        intent.setComponent(componentName);
+        intent.setData(createTargetPanelUri(PANEL_USER_SLOT));
+        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK | Intent.FLAG_ACTIVITY_RESET_TASK_IF_NEEDED);
+        intent.putExtra(EXTRA_TARGET_PANEL_ID, PANEL_USER_SLOT);
+        context.startActivity(intent);
+    }
+
+    static Uri createTargetPanelUri(String panelId) {
+        return new Uri.Builder()
+                .scheme("content")
+                .authority("com.android.car.scalableui")
+                .path("panel")
+                .appendQueryParameter("target_panel", panelId)
+                .build();
+    }
+
+    private static boolean isLaunchable(Context context, ComponentName componentName) {
+        Intent intent = new Intent(Intent.ACTION_MAIN);
+        intent.addCategory(Intent.CATEGORY_LAUNCHER);
+        intent.setComponent(componentName);
+        return context.getPackageManager().resolveActivity(intent, PackageManager.MATCH_DEFAULT_ONLY)
+                != null;
+    }
+}
