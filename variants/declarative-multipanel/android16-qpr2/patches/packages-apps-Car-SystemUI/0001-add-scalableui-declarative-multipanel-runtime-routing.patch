+    private final BroadcastReceiver mPanelEventReceiver = new BroadcastReceiver() {
+        @Override
+        public void onReceive(Context context, Intent intent) {
+            if (!ACTION_PANEL_EVENT.equals(intent.getAction())) {
+                return;
+            }
+            String eventId = intent.getStringExtra(EXTRA_EVENT_ID);
+            if (eventId == null || eventId.isEmpty()) {
+                Log.w(TAG, "Ignoring ScalableUI panel event without event id");
+                return;
+            }
+            Event event = new Event.Builder(eventId)
+                    .setPanelId(intent.getStringExtra(EXTRA_PANEL_ID))
+                    .setComponentName(intent.getStringExtra(EXTRA_COMPONENT_NAME))
+                    .setPackageName(intent.getStringExtra(EXTRA_PACKAGE_NAME))
+                    .build();
+            Log.i(TAG, "Dispatch ScalableUI panel event: " + eventId);
+            mEventDispatcher.executeEvent(event);
+        }
+    };
 
