+    private void registerPanelEventReceiver() {
+        if (mPanelEventReceiverRegistered) {
+            return;
+        }
+        IntentFilter filter = new IntentFilter(ACTION_PANEL_EVENT);
+        mContext.registerReceiverForAllUsers(mPanelEventReceiver, filter,
+                null, null, Context.RECEIVER_EXPORTED);
+        mPanelEventReceiverRegistered = true;
     }
