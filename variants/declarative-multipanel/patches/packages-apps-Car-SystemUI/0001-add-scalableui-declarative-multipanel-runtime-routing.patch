+        mContext = context;
         mActionConfigReader = actionConfigReader;
         mPanelConfigReader = panelConfigReader;
+        mEventDispatcher = eventDispatcher;
         mPanelAutoTaskStackTransitionHandlerDelegate = delegate;
     }
 
