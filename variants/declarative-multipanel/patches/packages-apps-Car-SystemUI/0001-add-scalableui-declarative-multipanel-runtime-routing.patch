 public class ScalableUIWMInitializer {
+    public static final String ACTION_PANEL_EVENT =
+            "com.android.car.scalableui.ACTION_PANEL_EVENT";
+    public static final String EXTRA_EVENT_ID = "event_id";
+    public static final String EXTRA_PANEL_ID = "panel_id";
+    public static final String EXTRA_COMPONENT_NAME = "component_name";
+    public static final String EXTRA_PACKAGE_NAME = "package_name";
+
+    private static final String TAG = ScalableUIWMInitializer.class.getSimpleName();
+
+    private final Context mContext;
     private final ActionConfigReader mActionConfigReader;
