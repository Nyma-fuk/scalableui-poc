+package com.android.car.scalableui.hmi.home;
+
+import android.content.ComponentName;
+import android.content.Context;
+import android.content.Intent;
+import android.net.Uri;
+
+final class WorkspaceRuntimeBridge {
+    static final String ACTION_WORKSPACE_COMMAND =
+            "com.android.car.scalableui.hmi.workspace.ACTION_COMMAND";
+    static final String ACTION_WORKSPACE_SYNC =
+            "com.android.car.scalableui.hmi.workspace.ACTION_SYNC";
+    static final String EXTRA_COMMAND = "com.android.car.scalableui.hmi.workspace.extra.COMMAND";
+    static final String EXTRA_PANEL_ID = "com.android.car.scalableui.hmi.workspace.extra.PANEL_ID";
+    static final String EXTRA_COMPONENT =
+            "com.android.car.scalableui.hmi.workspace.extra.COMPONENT";
+    static final String COMMAND_ASSIGN_COMPONENT = "assign_component";
+
+    private static final String EXTRA_TARGET_PANEL_ID =
+            "com.android.car.scalableui.extra.TARGET_PANEL_ID";
+    private static final String TARGET_PANEL_URI_SCHEME = "scalableui-hmi";
+    private static final String TARGET_PANEL_URI_HOST = "panel-launch";
+    private static final String TARGET_PANEL_URI_PARAM = "target_panel";
+
+    private WorkspaceRuntimeBridge() {}
+
+    static void requestSync(Context context) {
+        Intent intent = new Intent(ACTION_WORKSPACE_SYNC);
+        intent.setPackage("com.android.systemui");
+        context.sendBroadcast(intent);
+    }
+
+    static void sendCommand(Context context, String command, String panelId) {
+        Intent intent = new Intent(ACTION_WORKSPACE_COMMAND);
+        intent.putExtra(EXTRA_COMMAND, command);
+        if (panelId != null) {
+            intent.putExtra(EXTRA_PANEL_ID, panelId);
+        }
