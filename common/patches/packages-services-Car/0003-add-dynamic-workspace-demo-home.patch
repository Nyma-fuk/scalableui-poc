+package com.android.car.scalableui.hmi.home;
+
+import android.app.Activity;
+import android.graphics.Color;
+import android.graphics.LinearGradient;
+import android.graphics.Paint;
+import android.graphics.Shader;
+import android.os.Bundle;
+import android.view.View;
+
+public final class WorkspaceHomeActivity extends Activity {
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(new WorkspaceBackdropView(this));
+    }
+
+    @Override
+    protected void onResume() {
+        super.onResume();
+        WorkspaceRuntimeBridge.requestSync(this);
+    }
+
+    private static final class WorkspaceBackdropView extends View {
+        private final Paint mPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+
+        WorkspaceBackdropView(Activity activity) {
+            super(activity);
+        }
+
+        @Override
+        protected void onDraw(android.graphics.Canvas canvas) {
+            super.onDraw(canvas);
+            int width = getWidth();
+            int height = getHeight();
+            if (width <= 0 || height <= 0) {
+                return;
+            }
+            mPaint.setShader(new LinearGradient(
+                    0, 0, width, height,
+                    Color.rgb(16, 22, 30),
+                    Color.rgb(28, 40, 56),
+                    Shader.TileMode.CLAMP));
+            canvas.drawRect(0, 0, width, height, mPaint);
+
+            Paint glow = new Paint(Paint.ANTI_ALIAS_FLAG);
+            glow.setShader(new LinearGradient(
+                    width * 0.1f, height * 0.1f, width * 0.8f, height * 0.8f,
+                    Color.argb(90, 33, 150, 243),
+                    Color.argb(20, 255, 193, 7),
+                    Shader.TileMode.CLAMP));
+            canvas.drawCircle(width * 0.75f, height * 0.22f, width * 0.32f, glow);
+
+            Paint text = new Paint(Paint.ANTI_ALIAS_FLAG);
+            text.setColor(Color.rgb(240, 244, 249));
+            text.setTextSize(getResources().getDisplayMetrics().density * 24f);
+            text.setFakeBoldText(true);
+            canvas.drawText("Workspace", width * 0.06f, height * 0.11f, text);
+            text.setFakeBoldText(false);
+            text.setTextSize(getResources().getDisplayMetrics().density * 12f);
+            text.setColor(Color.argb(190, 220, 228, 239));
+            canvas.drawText("Add panels, drag headers to reorder, and resize with the rails.",
+                    width * 0.06f, height * 0.145f, text);
+        }
+    }
+}
