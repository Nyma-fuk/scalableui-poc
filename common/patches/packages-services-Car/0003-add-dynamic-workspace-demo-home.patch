@@ -0,0 +1,140 @@
+package com.android.car.scalableui.hmi.home;
+
+import android.content.ContentResolver;
+import android.content.Context;
+import android.os.SystemProperties;
+import android.os.UserHandle;
+import android.provider.Settings;
+import android.text.TextUtils;
+
+import org.json.JSONArray;
+import org.json.JSONException;
+import org.json.JSONObject;
+
+import java.util.ArrayList;
+import java.util.List;
+
+final class WorkspaceModelStore {
+    static final String PRODUCT_NAME = "sdk_car_scalableui_dynamic_workspace_x86_64";
+    private static final String SETTINGS_KEY = "scalableui_dynamic_workspace_model_v2";
+
+    private static final String KEY_VERSION = "version";
+    private static final String KEY_NEXT_PANEL_INDEX = "next_panel_index";
+    private static final String KEY_VIEWPORT_OFFSET_DP = "viewport_offset_dp";
+    private static final String KEY_PANELS = "panels";
+
+    private static final String KEY_PANEL_ID = "id";
+    private static final String KEY_COMPONENT = "component";
+    private static final String KEY_WIDTH_DP = "width_dp";
+
+    private static final int VERSION = 2;
+    private static final int DEFAULT_PANEL_WIDTH_DP = 460;
+    private static final String EMPTY_PANEL_COMPONENT =
+            "com.android.car.scalableui.hmi.home/.WorkspaceEmptyPanelActivity";
+
+    private WorkspaceModelStore() {}
+
+    static boolean isDynamicWorkspaceVariant() {
+        return PRODUCT_NAME.equals(android.os.Build.PRODUCT)
+                || PRODUCT_NAME.equals(SystemProperties.get("ro.product.name", ""))
+                || PRODUCT_NAME.equals(SystemProperties.get("ro.product.product.name", ""));
+    }
+
+    static Model load(Context context) {
+        ContentResolver resolver = context.getContentResolver();
+        String raw = Settings.Secure.getStringForUser(
+                resolver, SETTINGS_KEY, UserHandle.myUserId());
+        if (TextUtils.isEmpty(raw)) {
+            return createDefaultModel();
+        }
+        try {
+            JSONObject root = new JSONObject(raw);
+            Model model = new Model();
+            model.nextPanelIndex = Math.max(1, root.optInt(KEY_NEXT_PANEL_INDEX, 1));
+            model.viewportOffsetDp = Math.max(0, root.optInt(KEY_VIEWPORT_OFFSET_DP, 0));
+            JSONArray panels = root.optJSONArray(KEY_PANELS);
+            if (panels != null) {
+                for (int i = 0; i < panels.length(); i++) {
+                    JSONObject item = panels.optJSONObject(i);
+                    if (item == null) {
+                        continue;
+                    }
+                    String id = item.optString(KEY_PANEL_ID, "");
+                    String component = item.optString(KEY_COMPONENT, "");
+                    int widthDp = Math.max(280, item.optInt(KEY_WIDTH_DP, DEFAULT_PANEL_WIDTH_DP));
+                    if (id.isEmpty() || component.isEmpty()) {
+                        continue;
+                    }
+                    model.panels.add(new PanelRecord(id, component, widthDp));
+                }
+            }
+            if (model.panels.isEmpty()) {
+                return createDefaultModel();
+            }
+            return model;
+        } catch (JSONException e) {
+            return createDefaultModel();
+        }
+    }
+
+    static void save(Context context, Model model) {
+        Settings.Secure.putStringForUser(
+                context.getContentResolver(), SETTINGS_KEY, toJson(model), UserHandle.myUserId());
+    }
+
+    static Model createDefaultModel() {
+        Model model = new Model();
+        model.nextPanelIndex = 1;
+        model.viewportOffsetDp = 0;
+        return model;
+    }
+
+    static String emptyPanelComponent() {
+        return EMPTY_PANEL_COMPONENT;
+    }
+
+    static String nextPanelId(Model model) {
+        String id = "workspace_panel_" + model.nextPanelIndex;
+        model.nextPanelIndex++;
+        return id;
+    }
+
+    private static String toJson(Model model) {
+        JSONObject root = new JSONObject();
+        JSONArray panels = new JSONArray();
+        try {
+            root.put(KEY_VERSION, VERSION);
+            root.put(KEY_NEXT_PANEL_INDEX, Math.max(1, model.nextPanelIndex));
+            root.put(KEY_VIEWPORT_OFFSET_DP, Math.max(0, model.viewportOffsetDp));
+            for (PanelRecord record : model.panels) {
+                JSONObject item = new JSONObject();
+                item.put(KEY_PANEL_ID, record.id);
+                item.put(KEY_COMPONENT, record.componentName);
+                item.put(KEY_WIDTH_DP, record.widthDp);
+                panels.put(item);
+            }
+            root.put(KEY_PANELS, panels);
+        } catch (JSONException ignored) {
+            // JSONObject writes above are safe for primitive/string payloads.
+        }
+        return root.toString();
+    }
+
+    static final class Model {
+        final List<PanelRecord> panels = new ArrayList<>();
+        int nextPanelIndex;
+        int viewportOffsetDp;
+    }
+
+    static final class PanelRecord {
+        final String id;
+        String componentName;
+        int widthDp;
+
+        PanelRecord(String id, String componentName, int widthDp) {
+            this.id = id;
+            this.componentName = componentName;
+            this.widthDp = widthDp;
+        }
+    }
+}
