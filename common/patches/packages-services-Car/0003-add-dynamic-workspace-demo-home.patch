+package com.android.car.scalableui.hmi.home;
+
+import android.app.Activity;
+import android.graphics.Color;
+import android.graphics.Typeface;
+import android.graphics.drawable.GradientDrawable;
+import android.os.Bundle;
+import android.text.TextUtils;
+import android.view.Gravity;
+import android.view.View;
+import android.view.ViewGroup;
+import android.widget.Button;
+import android.widget.LinearLayout;
+import android.widget.ScrollView;
+import android.widget.TextView;
+
+import java.util.List;
+
+public final class WorkspaceAppPickerActivity extends Activity {
+    private String mTargetPanelId;
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        mTargetPanelId = getIntent().getStringExtra(WorkspaceRuntimeBridge.EXTRA_PANEL_ID);
+        if (TextUtils.isEmpty(mTargetPanelId)) {
+            finish();
+            return;
+        }
+        setContentView(createContent());
+    }
+
+    private View createContent() {
+        WorkspaceModelStore.Model model = WorkspaceModelStore.load(this);
+        String currentComponent = findCurrentComponent(model, mTargetPanelId);
+        List<InstalledAppCatalog.AppEntry> apps = InstalledAppCatalog.queryLaunchableApps(this);
+
+        LinearLayout shell = new LinearLayout(this);
+        shell.setOrientation(LinearLayout.VERTICAL);
+        shell.setBackgroundColor(Color.rgb(10, 14, 20));
+
+        shell.addView(createTopBar(),
+                new LinearLayout.LayoutParams(
+                        ViewGroup.LayoutParams.MATCH_PARENT,
+                        (int) (76 * getResources().getDisplayMetrics().density)));
+
+        ScrollView scrollView = new ScrollView(this);
+        scrollView.setFillViewport(true);
+        LinearLayout list = new LinearLayout(this);
+        list.setOrientation(LinearLayout.VERTICAL);
+        int pad = (int) (24 * getResources().getDisplayMetrics().density);
+        list.setPadding(pad, pad, pad, pad);
+        scrollView.addView(list, new ViewGroup.LayoutParams(
+                ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.WRAP_CONTENT));
+
+        list.addView(createHeadline("Choose app for " + mTargetPanelId));
+        list.addView(createSubline("This picker writes the workspace model and relaunches the"
+                + " target panel."));
+
+        Button emptyPanel = createAppButton(
+                "Empty panel",
+                "Placeholder panel with add-app affordance",
+                currentComponent.equals(WorkspaceModelStore.emptyPanelComponent()),
+                null);
+        emptyPanel.setOnClickListener(v -> applySelection(WorkspaceModelStore.emptyPanelComponent()));
+        LinearLayout.LayoutParams emptyParams = new LinearLayout.LayoutParams(
+                ViewGroup.LayoutParams.MATCH_PARENT,
+                ViewGroup.LayoutParams.WRAP_CONTENT);
+        emptyParams.bottomMargin = (int) (10 * getResources().getDisplayMetrics().density);
+        list.addView(emptyPanel, emptyParams);
+
+        for (InstalledAppCatalog.AppEntry app : apps) {
+            Button button = createAppButton(app.label, app.packageName,
+                    app.componentName.equals(currentComponent), app.icon);
+            button.setOnClickListener(v -> applySelection(app.componentName));
+            LinearLayout.LayoutParams params = new LinearLayout.LayoutParams(
+                    ViewGroup.LayoutParams.MATCH_PARENT,
+                    ViewGroup.LayoutParams.WRAP_CONTENT);
+            params.bottomMargin = (int) (10 * getResources().getDisplayMetrics().density);
+            list.addView(button, params);
+        }
+
+        shell.addView(scrollView, new LinearLayout.LayoutParams(
+                ViewGroup.LayoutParams.MATCH_PARENT, 0, 1f));
+        return shell;
+    }
+
+    private View createTopBar() {
+        LinearLayout bar = new LinearLayout(this);
+        bar.setOrientation(LinearLayout.HORIZONTAL);
+        bar.setGravity(Gravity.CENTER_VERTICAL);
+        int pad = (int) (20 * getResources().getDisplayMetrics().density);
+        bar.setPadding(pad, pad / 2, pad, pad / 2);
+        bar.setBackgroundColor(Color.rgb(18, 24, 32));
+
+        TextView title = new TextView(this);
+        title.setText("Panel app picker");
+        title.setTextColor(Color.WHITE);
+        title.setTextSize(20f);
+        title.setTypeface(Typeface.DEFAULT_BOLD);
+        LinearLayout.LayoutParams titleParams = new LinearLayout.LayoutParams(
+                0, ViewGroup.LayoutParams.WRAP_CONTENT, 1f);
+        bar.addView(title, titleParams);
+
+        Button close = createTonalButton("Close");
+        close.setOnClickListener(v -> finish());
+        bar.addView(close, new LinearLayout.LayoutParams(
+                ViewGroup.LayoutParams.WRAP_CONTENT, ViewGroup.LayoutParams.WRAP_CONTENT));
+        return bar;
+    }
+
+    private TextView createHeadline(String text) {
+        TextView view = new TextView(this);
+        view.setText(text);
+        view.setTextColor(Color.WHITE);
+        view.setTextSize(26f);
+        view.setTypeface(Typeface.DEFAULT_BOLD);
+        return view;
+    }
+
+    private TextView createSubline(String text) {
+        TextView view = new TextView(this);
+        view.setText(text);
+        view.setTextColor(Color.rgb(183, 197, 210));
+        view.setTextSize(14f);
+        view.setPadding(0, dp(8), 0, dp(20));
+        return view;
+    }
+
+    private Button createAppButton(String title, String subtitle, boolean selected,
+            android.graphics.drawable.Drawable iconDrawable) {
+        Button button = new Button(this);
+        button.setAllCaps(false);
+        button.setGravity(Gravity.START | Gravity.CENTER_VERTICAL);
+        button.setTextAlignment(View.TEXT_ALIGNMENT_VIEW_START);
+        button.setText(title + "\n" + subtitle);
+        button.setTextColor(selected ? Color.BLACK : Color.WHITE);
+        button.setTextSize(15f);
+        button.setTypeface(Typeface.DEFAULT_BOLD);
+        button.setPadding(dp(20), dp(16), dp(20), dp(16));
+        GradientDrawable background = new GradientDrawable();
+        background.setCornerRadius(dp(24));
+        background.setStroke(dp(1), Color.argb(60, 255, 255, 255));
+        background.setColor(selected ? Color.rgb(129, 199, 132) : Color.rgb(26, 35, 44));
+        button.setBackground(background);
+        if (iconDrawable != null) {
+            android.graphics.drawable.Drawable icon = iconDrawable.mutate();
+            icon.setBounds(0, 0, dp(28), dp(28));
+            button.setCompoundDrawablePadding(dp(14));
+            button.setCompoundDrawablesRelative(icon, null, null, null);
+        }
+        return button;
+    }
+
+    private Button createTonalButton(String text) {
+        Button button = new Button(this);
+        button.setText(text);
+        button.setAllCaps(false);
+        button.setTextColor(Color.WHITE);
+        GradientDrawable background = new GradientDrawable();
+        background.setCornerRadius(dp(20));
+        background.setColor(Color.rgb(43, 57, 75));
+        button.setBackground(background);
+        return button;
+    }
+
+    private void applySelection(String componentName) {
+        WorkspaceRuntimeBridge.assignComponent(this, mTargetPanelId, componentName);
+        finish();
+    }
+
+    private static String findCurrentComponent(WorkspaceModelStore.Model model, String panelId) {
+        for (WorkspaceModelStore.PanelRecord panel : model.panels) {
+            if (panelId.equals(panel.id)) {
+                return panel.componentName;
+            }
+        }
+        return "";
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+}
