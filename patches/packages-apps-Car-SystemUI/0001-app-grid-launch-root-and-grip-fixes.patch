+    public ActivityManager.RunningTaskInfo findReusableTask(ComponentName componentName,
+            int displayId, int excludedTaskId) {
+        synchronized (mLock) {
+            ActivityManager.RunningTaskInfo match = null;
+            for (String panelId : mPanelTaskMap.keySet()) {
+                for (ActivityManager.RunningTaskInfo taskInfo : mPanelTaskMap.get(panelId).values()) {
+                    if (taskInfo.taskId == excludedTaskId
+                            || taskInfo.displayId != displayId
+                            || !isTaskReusable(taskInfo)
+                            || !matchesComponent(taskInfo, componentName)) {
