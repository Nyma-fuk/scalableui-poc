+    public void applySplit(float splitRatioX, float splitRatioRightY) {
+        if (!isEditableHomeProduct()) {
+            return;
+        }
+        mMainExecutor.execute(() -> applySplitOnMain(splitRatioX, splitRatioRightY));
+    }
