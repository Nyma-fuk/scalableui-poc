+++ b/src/com/android/systemui/car/wm/scalableui/workspace/WorkspaceModelStore.java
@@ -0,0 +1,120 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.ContentResolver;
+import android.content.Context;
+import android.os.UserHandle;
+import android.provider.Settings;
+import android.text.TextUtils;
+
+import org.json.JSONArray;
+import org.json.JSONException;
+import org.json.JSONObject;
+
+import java.util.ArrayList;
+import java.util.List;
+
+final class WorkspaceModelStore {
+    private static final String KEY_VERSION = "version";
+    private static final String KEY_NEXT_PANEL_INDEX = "next_panel_index";
+    private static final String KEY_VIEWPORT_OFFSET_DP = "viewport_offset_dp";
+    private static final String KEY_PANELS = "panels";
+    private static final String KEY_PANEL_ID = "id";
+    private static final String KEY_COMPONENT = "component";
+    private static final String KEY_WIDTH_DP = "width_dp";
+
+    private static final int VERSION = 2;
+
+    private WorkspaceModelStore() {}
+
+    static Model load(Context context) {
+        ContentResolver resolver = context.getContentResolver();
+        String raw = Settings.Secure.getStringForUser(
+                resolver, WorkspaceConstants.MODEL_SETTINGS_KEY, UserHandle.myUserId());
+        if (TextUtils.isEmpty(raw)) {
+            return createDefaultModel();
+        }
+        try {
+            JSONObject root = new JSONObject(raw);
+            Model model = new Model();
+            model.nextPanelIndex = Math.max(1, root.optInt(KEY_NEXT_PANEL_INDEX, 1));
+            model.viewportOffsetDp = Math.max(0, root.optInt(KEY_VIEWPORT_OFFSET_DP, 0));
+            JSONArray panels = root.optJSONArray(KEY_PANELS);
+            if (panels != null) {
+                for (int i = 0; i < panels.length(); i++) {
+                    JSONObject item = panels.optJSONObject(i);
+                    if (item == null) {
+                        continue;
+                    }
+                    String id = item.optString(KEY_PANEL_ID, "");
+                    String component = item.optString(KEY_COMPONENT, "");
+                    int widthDp = Math.max(280, item.optInt(KEY_WIDTH_DP, 460));
+                    if (id.isEmpty() || component.isEmpty()) {
+                        continue;
+                    }
+                    model.panels.add(new PanelRecord(id, component, widthDp));
+                }
+            }
+            if (model.panels.isEmpty()) {
+                return createDefaultModel();
+            }
+            return model;
+        } catch (JSONException e) {
+            return createDefaultModel();
+        }
+    }
+
+    static void save(Context context, Model model) {
+        Settings.Secure.putStringForUser(context.getContentResolver(),
+                WorkspaceConstants.MODEL_SETTINGS_KEY, toJson(model), UserHandle.myUserId());
+    }
+
+    static Model createDefaultModel() {
+        Model model = new Model();
+        model.nextPanelIndex = 1;
+        return model;
+    }
+
+    static String nextPanelId(Model model) {
+        String id = "workspace_panel_" + model.nextPanelIndex;
+        model.nextPanelIndex++;
+        return id;
+    }
+
+    private static String toJson(Model model) {
+        JSONObject root = new JSONObject();
+        JSONArray panels = new JSONArray();
+        try {
+            root.put(KEY_VERSION, VERSION);
+            root.put(KEY_NEXT_PANEL_INDEX, model.nextPanelIndex);
+            root.put(KEY_VIEWPORT_OFFSET_DP, model.viewportOffsetDp);
+            for (PanelRecord panel : model.panels) {
+                JSONObject item = new JSONObject();
+                item.put(KEY_PANEL_ID, panel.id);
+                item.put(KEY_COMPONENT, panel.componentName);
+                item.put(KEY_WIDTH_DP, panel.widthDp);
+                panels.put(item);
+            }
+            root.put(KEY_PANELS, panels);
+        } catch (JSONException ignored) {
+        }
+        return root.toString();
+    }
+
+    static final class Model {
+        final List<PanelRecord> panels = new ArrayList<>();
+        int nextPanelIndex;
+        int viewportOffsetDp;
+    }
+
+    static final class PanelRecord {
+        final String id;
+        String componentName;
+        int widthDp;
+
+        PanelRecord(String id, String componentName, int widthDp) {
+            this.id = id;
+            this.componentName = componentName;
+            this.widthDp = widthDp;
+        }
+    }
+}
diff --git a/src/com/android/systemui/car/wm/scalableui/workspace/WorkspacePanelStateController.java b/src/com/android/systemui/car/wm/scalableui/workspace/WorkspacePanelStateController.java
new file mode 100644
index 0000000000000000000000000000000000000000..c51ad2c8198f6cb494fc2028f920af294093cbf8
--- /dev/null
+++ b/src/com/android/systemui/car/wm/scalableui/workspace/WorkspacePanelStateController.java
@@ -0,0 +1,213 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.graphics.Insets;
+import android.graphics.Rect;
+import android.view.SurfaceControl;
+
+import com.android.car.scalableui.manager.StateManager;
+import com.android.car.scalableui.model.PanelControllerMetadata;
+import com.android.car.scalableui.model.PanelState;
+import com.android.car.scalableui.model.Role;
+import com.android.car.scalableui.model.Variant;
+import com.android.car.scalableui.panel.PanelPool;
+import com.android.systemui.car.wm.scalableui.panel.BasePanel;
+import com.android.systemui.car.wm.scalableui.panel.PanelUtils;
+import com.android.systemui.car.wm.scalableui.panel.TaskPanel;
+import com.android.wm.shell.automotive.AutoSurfaceTransaction;
+import com.android.wm.shell.automotive.AutoSurfaceTransactionFactory;
+import com.android.wm.shell.automotive.AutoTaskStackState;
+import com.android.wm.shell.automotive.AutoTaskStackTransaction;
+
+import java.util.HashSet;
+import java.util.Set;
+
+final class WorkspacePanelStateController {
+    private final AutoSurfaceTransactionFactory mAutoSurfaceTransactionFactory;
+    private final PanelUtils mPanelUtils;
+    private final Set<String> mKnownTaskPanelIds = new HashSet<>();
+    private final Set<String> mKnownDecorPanelIds = new HashSet<>();
+
+    WorkspacePanelStateController(AutoSurfaceTransactionFactory autoSurfaceTransactionFactory,
+            PanelUtils panelUtils) {
+        mAutoSurfaceTransactionFactory = autoSurfaceTransactionFactory;
+        mPanelUtils = panelUtils;
+    }
+
+    void ensureTaskPanelState(String panelId) {
+        if (StateManager.getPanelState(panelId) != null) {
+            PanelPool.getInstance().getPanel(panelId);
+            return;
+        }
+        Role role = new Role.Builder().addPersistentActivity(
+                WorkspaceConstants.EMPTY_PANEL_COMPONENT).build();
+        Variant variant = new Variant.Builder("opened")
+                .setVisibility(true)
+                .setLayer(400)
+                .setBounds(WorkspaceGeometry.offscreenBounds())
+                .setSafeBounds(WorkspaceGeometry.offscreenBounds())
+                .setInsets(Insets.NONE)
+                .build();
+        PanelState.Builder builder = new PanelState.Builder(panelId, role);
+        builder.setDefaultVariant("opened");
+        builder.addVariant(variant);
+        StateManager.addState(builder.build());
+        mKnownTaskPanelIds.add(panelId);
+        PanelPool.getInstance().getPanel(panelId);
+    }
+
+    void ensureHeaderDecorState(String panelId) {
+        String headerId = WorkspaceGeometry.headerPanelId(panelId);
+        if (StateManager.getPanelState(headerId) != null) {
+            PanelPool.getInstance().getPanel(headerId);
+            return;
+        }
+        PanelControllerMetadata metadata = PanelControllerMetadata.builder(headerId)
+                .addConfiguration(PanelControllerMetadata.CONTROLLER_NAME_TAG,
+                        WorkspaceHeaderViewController.class.getName())
+                .addConfiguration(PanelControllerMetadata.VIEW_TAG,
+                        WorkspaceHeaderView.class.getName())
+                .addConfiguration(WorkspaceConstants.CONTROLLER_CONFIG_PANEL_ID, panelId)
+                .build();
+        addDecorState(headerId, metadata, 640);
+    }
+
+    void ensureGripDecorState(String leftPanelId) {
+        String gripId = WorkspaceGeometry.gripPanelId(leftPanelId);
+        if (StateManager.getPanelState(gripId) != null) {
+            PanelPool.getInstance().getPanel(gripId);
+            return;
+        }
+        PanelControllerMetadata metadata = PanelControllerMetadata.builder(gripId)
+                .addConfiguration(PanelControllerMetadata.CONTROLLER_NAME_TAG,
+                        WorkspaceGripViewController.class.getName())
+                .addConfiguration(PanelControllerMetadata.VIEW_TAG,
+                        WorkspaceGripView.class.getName())
+                .addConfiguration(WorkspaceConstants.CONTROLLER_CONFIG_LEFT_PANEL_ID, leftPanelId)
+                .build();
+        addDecorState(gripId, metadata, 650);
+    }
+
+    void ensureGlobalDecorState(String panelId, String controllerName, String viewName) {
+        if (StateManager.getPanelState(panelId) != null) {
+            PanelPool.getInstance().getPanel(panelId);
+            return;
+        }
+        PanelControllerMetadata metadata = PanelControllerMetadata.builder(panelId)
+                .addConfiguration(PanelControllerMetadata.CONTROLLER_NAME_TAG, controllerName)
+                .addConfiguration(PanelControllerMetadata.VIEW_TAG, viewName)
+                .build();
+        addDecorState(panelId, metadata, 720);
+    }
+
+    boolean updateTaskPanel(String panelId, Rect bounds, AutoTaskStackTransaction transaction,
+            boolean visible, boolean commitTaskStackTransition) {
+        PanelState panelState = StateManager.getPanelState(panelId);
+        if (panelState == null || panelState.getCurrentVariant() == null) {
+            return false;
+        }
+        Variant variant = panelState.getCurrentVariant();
+        Rect safeBounds = new Rect(bounds);
+        variant.setRuntimeBounds(bounds);
+        variant.setRuntimeSafeBounds(safeBounds);
+        variant.setRuntimeVisibility(visible);
+        StateManager.applyState(panelState);
+
+        if (!commitTaskStackTransition) {
+            return false;
+        }
+        TaskPanel taskPanel = mPanelUtils.getTaskPanel(
+                panel -> panelId.equals(panel.getPanelId()) && panel.getRootStack() != null);
+        if (taskPanel == null) {
+            return false;
+        }
+        AutoTaskStackState taskState = new AutoTaskStackState(new Rect(bounds), visible,
+                taskPanel.getLayer());
+        transaction.setTaskStackState(taskPanel.getRootStack().getId(), taskState);
+        transaction.setSafeRegionBounds(taskPanel.getRootStack().getId(), safeBounds);
+        return true;
+    }
+
+    void updateDecorPanel(String panelId, Rect bounds, int layer, boolean visible) {
+        PanelState panelState = StateManager.getPanelState(panelId);
+        if (panelState == null || panelState.getCurrentVariant() == null) {
+            return;
+        }
+        Variant variant = panelState.getCurrentVariant();
+        variant.setRuntimeBounds(bounds);
+        variant.setRuntimeSafeBounds(new Rect(bounds));
+        variant.setRuntimeLayer(layer);
+        variant.setRuntimeVisibility(visible);
+        StateManager.applyState(panelState);
+    }
+
+    void hideInactiveDynamicPanels(Set<String> activeIds,
+            AutoTaskStackTransaction taskTransaction) {
+        for (String panelId : mKnownTaskPanelIds) {
+            if (!activeIds.contains(panelId)) {
+                updateTaskPanel(panelId, WorkspaceGeometry.offscreenBounds(), taskTransaction,
+                        false, true);
+            }
+        }
+        for (String panelId : mKnownDecorPanelIds) {
+            if (!activeIds.contains(panelId)) {
+                updateDecorPanel(panelId, WorkspaceGeometry.offscreenBounds(), 1, false);
+            }
+        }
+    }
+
+    void updateSurfaceStates(Set<String> panelIds, boolean includeTaskPanels,
+            boolean includeKnownDecorPanels) {
+        AutoSurfaceTransaction autoSurfaceTransaction =
+                mAutoSurfaceTransactionFactory.createTransaction("WORKSPACE_DYNAMIC_LAYOUT");
+        SurfaceControl.Transaction tx = new SurfaceControl.Transaction();
+        Set<String> allIds = new HashSet<>();
+        if (includeTaskPanels) {
+            allIds.addAll(mKnownTaskPanelIds);
+        }
+        if (includeKnownDecorPanels) {
+            allIds.addAll(mKnownDecorPanelIds);
+        }
+        allIds.addAll(panelIds);
+        for (String panelId : allIds) {
+            if (!includeTaskPanels && mKnownTaskPanelIds.contains(panelId)) {
+                continue;
+            }
+            BasePanel basePanel = mPanelUtils.getBasePanel(panel -> panelId.equals(
+                    panel.getPanelId()));
+            if (basePanel == null) {
+                continue;
+            }
+            PanelState panelState = StateManager.getPanelState(panelId);
+            Variant currentVariant = panelState == null ? null : panelState.getCurrentVariant();
+            basePanel.update(autoSurfaceTransaction, tx, currentVariant);
+        }
+        tx.apply();
+        autoSurfaceTransaction.apply();
+    }
+
+    void resetDecorPanels(Set<String> activeIds) {
+        for (String decorId : activeIds) {
+            BasePanel panel = mPanelUtils.getBasePanel(base -> decorId.equals(base.getPanelId()));
+            if (panel != null && decorId.startsWith(PanelState.DECOR_PANEL_ID_PREFIX)) {
+                panel.reset();
+            }
+        }
+    }
+
+    private void addDecorState(String panelId, PanelControllerMetadata metadata, int layer) {
+        Role role = new Role.Builder().setIsDefault(true).build();
+        Variant variant = new Variant.Builder("opened")
+                .setVisibility(true)
+                .setLayer(layer)
+                .setBounds(WorkspaceGeometry.offscreenBounds())
+                .setSafeBounds(WorkspaceGeometry.offscreenBounds())
+                .build();
+        PanelState.Builder builder = new PanelState.Builder(panelId, role);
+        builder.setDefaultVariant("opened");
+        builder.addVariant(variant);
+        builder.setPanelControllerMetadata(metadata);
+        StateManager.addState(builder.build());
+        mKnownDecorPanelIds.add(panelId);
+        PanelPool.getInstance().getPanel(panelId);
+    }
+}
diff --git a/src/com/android/systemui/car/wm/scalableui/workspace/WorkspaceRuntimeLayoutController.java b/src/com/android/systemui/car/wm/scalableui/workspace/WorkspaceRuntimeLayoutController.java
new file mode 100644
index 0000000000000000000000000000000000000000..d771b411ce5e07c231867a1f5b57f44af73ee54a
--- /dev/null
+++ b/src/com/android/systemui/car/wm/scalableui/workspace/WorkspaceRuntimeLayoutController.java
@@ -0,0 +1,438 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.Context;
+import android.content.Intent;
+import android.os.Build;
+import android.os.SystemProperties;
+import android.text.TextUtils;
+import android.util.Log;
+
+import androidx.annotation.Nullable;
+
+import com.android.systemui.car.wm.scalableui.panel.PanelUtils;
+import com.android.wm.shell.automotive.AutoSurfaceTransactionFactory;
+import com.android.wm.shell.automotive.AutoTaskStackController;
+import com.android.wm.shell.automotive.AutoTaskStackTransaction;
+import com.android.wm.shell.common.ShellExecutor;
+import com.android.wm.shell.dagger.WMSingleton;
+import com.android.wm.shell.shared.annotations.ShellMainThread;
+
+import java.util.HashSet;
+import java.util.Set;
+
+import javax.inject.Inject;
+
+@WMSingleton
+public class WorkspaceRuntimeLayoutController {
+    private static final String TAG = "WorkspaceRuntime";
+
+    private final Context mContext;
+    private final AutoTaskStackController mAutoTaskStackController;
+    private final ShellExecutor mMainExecutor;
+    private final WorkspaceGeometry mGeometry;
+    private final WorkspacePanelStateController mPanelStateController;
+    private final WorkspaceTaskRouter mTaskRouter;
+
+    @Nullable
+    private WorkspaceModelStore.Model mModel;
+    @Nullable
+    private DragState mMoveDragState;
+    @Nullable
+    private ResizeDragState mResizeDragState;
+    @Nullable
+    private PanDragState mPanDragState;
+
+    @Inject
+    public WorkspaceRuntimeLayoutController(Context context,
+            AutoTaskStackController autoTaskStackController,
+            AutoSurfaceTransactionFactory autoSurfaceTransactionFactory,
+            PanelUtils panelUtils,
+            @ShellMainThread ShellExecutor mainExecutor) {
+        mContext = context;
+        mAutoTaskStackController = autoTaskStackController;
+        mMainExecutor = mainExecutor;
+        mGeometry = new WorkspaceGeometry(context);
+        mPanelStateController = new WorkspacePanelStateController(autoSurfaceTransactionFactory,
+                panelUtils);
+        mTaskRouter = new WorkspaceTaskRouter(context, panelUtils);
+    }
+
+    public void init() {
+        if (!isWorkspaceProduct()) {
+            return;
+        }
+        Log.i(TAG, "Initializing dynamic workspace runtime");
+        mMainExecutor.execute(() -> {
+            mModel = WorkspaceModelStore.load(mContext);
+            applyModel(mModel, true, false);
+        });
+    }
+
+    public void onSyncRequested() {
+        if (!isWorkspaceProduct()) {
+            return;
+        }
+        Log.i(TAG, "Workspace sync requested");
+        mMainExecutor.execute(() -> {
+            mModel = WorkspaceModelStore.load(mContext);
+            applyModel(mModel, true, true);
+        });
+    }
+
+    public void onCommand(Intent intent) {
+        if (!isWorkspaceProduct()) {
+            return;
+        }
+        mMainExecutor.execute(() -> handleCommandOnMain(intent));
+    }
+
+    private void handleCommandOnMain(Intent intent) {
+        WorkspaceModelStore.Model model = mModel != null ? mModel : WorkspaceModelStore.load(mContext);
+        String command = intent.getStringExtra(WorkspaceConstants.EXTRA_COMMAND);
+        String panelId = intent.getStringExtra(WorkspaceConstants.EXTRA_PANEL_ID);
+        String componentName = intent.getStringExtra(WorkspaceConstants.EXTRA_COMPONENT);
+        float deltaDp = intent.getFloatExtra(WorkspaceConstants.EXTRA_DELTA_DP, 0f);
+        if (TextUtils.isEmpty(command)) {
+            return;
+        }
+        Log.i(TAG, "Workspace command: " + command + " panel=" + panelId);
+        boolean persist = false;
+        boolean relaunchChangedPanels = false;
+        boolean refreshDecor = false;
+        boolean applyLayout = true;
+        boolean updateTaskStacks = true;
+        boolean updateTaskPanelStates = true;
+        boolean includeTaskSurfaces = true;
+        boolean commitTaskStackTransition = true;
+        boolean openPicker = false;
+        long openPickerDelayMs = 0L;
+        String pickerPanelId = null;
+        switch (command) {
+            case WorkspaceConstants.COMMAND_ADD_PANEL -> {
+                String newPanelId = WorkspaceModelStore.nextPanelId(model);
+                model.panels.add(new WorkspaceModelStore.PanelRecord(newPanelId,
+                        WorkspaceConstants.EMPTY_PANEL_COMPONENT, 420));
+                persist = true;
+                relaunchChangedPanels = true;
+                refreshDecor = true;
+                openPicker = true;
+                openPickerDelayMs = 350L;
+                pickerPanelId = newPanelId;
+            }
+            case WorkspaceConstants.COMMAND_REMOVE_PANEL -> {
+                if (panelId != null) {
+                    model.panels.removeIf(panel -> panel.id.equals(panelId));
+                    persist = true;
+                    refreshDecor = true;
+                }
+            }
+            case WorkspaceConstants.COMMAND_CENTER_VIEW -> {
+                model.viewportOffsetDp = 0;
+                persist = true;
+            }
+            case WorkspaceConstants.COMMAND_ASSIGN_COMPONENT -> {
+                if (panelId != null && componentName != null && !componentName.isEmpty()) {
+                    for (WorkspaceModelStore.PanelRecord panel : model.panels) {
+                        if (panelId.equals(panel.id)) {
+                            panel.componentName = componentName;
+                            persist = true;
+                            relaunchChangedPanels = true;
+                            break;
+                        }
+                    }
+                }
+            }
+            case WorkspaceConstants.COMMAND_OPEN_PICKER -> {
+                if (panelId != null) {
+                    openPicker = true;
+                    pickerPanelId = panelId;
+                    applyLayout = false;
+                }
+            }
+            case WorkspaceConstants.COMMAND_MOVE_START -> {
+                if (panelId != null) {
+                    int index = indexOf(model, panelId);
+                    if (index >= 0) {
+                        mMoveDragState = new DragState(panelId, index);
+                    }
+                }
+                applyLayout = false;
+            }
+            case WorkspaceConstants.COMMAND_MOVE_UPDATE -> {
+                if (mMoveDragState != null && panelId != null && panelId.equals(mMoveDragState.panelId)) {
+                    maybeReorder(model, mMoveDragState, deltaDp);
+                    updateTaskStacks = false;
+                    updateTaskPanelStates = false;
+                    includeTaskSurfaces = false;
+                    commitTaskStackTransition = false;
+                }
+            }
+            case WorkspaceConstants.COMMAND_MOVE_END -> {
+                mMoveDragState = null;
+                persist = true;
+            }
+            case WorkspaceConstants.COMMAND_RESIZE_START -> {
+                if (panelId != null) {
+                    int leftIndex = indexOf(model, panelId);
+                    if (leftIndex >= 0 && leftIndex < model.panels.size() - 1) {
+                        WorkspaceModelStore.PanelRecord left = model.panels.get(leftIndex);
+                        WorkspaceModelStore.PanelRecord right = model.panels.get(leftIndex + 1);
+                        mResizeDragState = new ResizeDragState(
+                                panelId, left.widthDp, right.widthDp);
+                    }
+                }
+                applyLayout = false;
+            }
+            case WorkspaceConstants.COMMAND_RESIZE_UPDATE -> {
+                if (mResizeDragState != null && panelId != null
+                        && panelId.equals(mResizeDragState.leftPanelId)) {
+                    applyResize(model, mResizeDragState, deltaDp);
+                    updateResizePreview(model, mResizeDragState.leftPanelId);
+                    applyLayout = false;
+                    updateTaskStacks = false;
+                    updateTaskPanelStates = false;
+                    includeTaskSurfaces = false;
+                    commitTaskStackTransition = false;
+                }
+            }
+            case WorkspaceConstants.COMMAND_RESIZE_END -> {
+                mResizeDragState = null;
+                persist = true;
+                // Commit the visual TaskPanel surfaces without asking ActivityTaskManager to
+                // relayout the apps during the drag release. The workspace home itself is a HOME
+                // task; sending a full task-stack transition here can try to mutate that task type.
+                updateTaskStacks = false;
+                updateTaskPanelStates = true;
+                includeTaskSurfaces = true;
+                commitTaskStackTransition = false;
+            }
+            case WorkspaceConstants.COMMAND_PAN_START -> {
+                mPanDragState = new PanDragState(model.viewportOffsetDp);
+                applyLayout = false;
+            }
+            case WorkspaceConstants.COMMAND_PAN_UPDATE -> {
+                if (mPanDragState != null) {
+                    model.viewportOffsetDp = Math.max(0,
+                            mPanDragState.startViewportDp - Math.round(deltaDp));
+                    updateTaskStacks = false;
+                    updateTaskPanelStates = false;
+                    includeTaskSurfaces = false;
+                    commitTaskStackTransition = false;
+                }
+            }
+            case WorkspaceConstants.COMMAND_PAN_END -> {
+                mPanDragState = null;
+                persist = true;
+            }
+            default -> {
+                return;
+            }
+        }
+        clampViewport(model);
+        if (persist) {
+            WorkspaceModelStore.save(mContext, model);
+        }
+        mModel = model;
+        if (applyLayout) {
+            if (updateTaskStacks) {
+                updateTaskPanelStates = true;
+                includeTaskSurfaces = true;
+                commitTaskStackTransition = true;
+            }
+            applyModel(model, relaunchChangedPanels, refreshDecor, updateTaskPanelStates,
+                    includeTaskSurfaces, commitTaskStackTransition);
+        }
+        if (openPicker && pickerPanelId != null) {
+            final String panelIdToPick = pickerPanelId;
+            if (openPickerDelayMs > 0) {
+                mMainExecutor.executeDelayed(() -> mTaskRouter.launchPickerFullscreen(panelIdToPick),
+                        openPickerDelayMs);
+            } else {
+                mTaskRouter.launchPickerFullscreen(panelIdToPick);
+            }
+        }
+    }
+
+    private void maybeReorder(WorkspaceModelStore.Model model, DragState dragState, float deltaDp) {
+        int currentIndex = indexOf(model, dragState.panelId);
+        if (currentIndex < 0) {
+            return;
+        }
+        if (deltaDp > 140 && currentIndex < model.panels.size() - 1) {
+            WorkspaceModelStore.PanelRecord panel = model.panels.remove(currentIndex);
+            model.panels.add(currentIndex + 1, panel);
+            dragState.resetThreshold();
+        } else if (deltaDp < -140 && currentIndex > 0) {
+            WorkspaceModelStore.PanelRecord panel = model.panels.remove(currentIndex);
+            model.panels.add(currentIndex - 1, panel);
+            dragState.resetThreshold();
+        }
+    }
+
+    private void applyResize(WorkspaceModelStore.Model model, ResizeDragState dragState, float deltaDp) {
+        int leftIndex = indexOf(model, dragState.leftPanelId);
+        if (leftIndex < 0 || leftIndex >= model.panels.size() - 1) {
+            return;
+        }
+        WorkspaceModelStore.PanelRecord left = model.panels.get(leftIndex);
+        WorkspaceModelStore.PanelRecord right = model.panels.get(leftIndex + 1);
+        int leftWidth = mGeometry.clampWidth(Math.round(dragState.startLeftWidthDp + deltaDp));
+        int rightWidth = mGeometry.clampWidth(Math.round(dragState.startRightWidthDp - deltaDp));
+        int total = dragState.startLeftWidthDp + dragState.startRightWidthDp;
+        if (leftWidth + rightWidth != total) {
+            rightWidth = mGeometry.clampWidth(total - leftWidth);
+            leftWidth = mGeometry.clampWidth(total - rightWidth);
+        }
+        left.widthDp = leftWidth;
+        right.widthDp = rightWidth;
+    }
+
+    private void applyModel(WorkspaceModelStore.Model model, boolean relaunchChangedPanels,
+            boolean structureOrUiChanged) {
+        applyModel(model, relaunchChangedPanels, structureOrUiChanged, true, true, true);
+    }
+
+    private void applyModel(WorkspaceModelStore.Model model, boolean relaunchChangedPanels,
+            boolean structureOrUiChanged, boolean updateTaskStacks) {
+        applyModel(model, relaunchChangedPanels, structureOrUiChanged, updateTaskStacks,
+                updateTaskStacks, updateTaskStacks);
+    }
+
+    private void applyModel(WorkspaceModelStore.Model model, boolean relaunchChangedPanels,
+            boolean structureOrUiChanged, boolean updateTaskPanelStates, boolean includeTaskSurfaces,
+            boolean commitTaskStackTransition) {
+        if (model == null) {
+            return;
+        }
+        mPanelStateController.ensureGlobalDecorState(WorkspaceConstants.TOOLBAR_PANEL_ID,
+                WorkspaceToolbarViewController.class.getName(),
+                WorkspaceToolbarView.class.getName());
+        mPanelStateController.ensureGlobalDecorState(WorkspaceConstants.VIEWPORT_PANEL_ID,
+                WorkspaceViewportHandleViewController.class.getName(),
+                WorkspaceViewportHandleView.class.getName());
+
+        WorkspaceGeometry.Layout layout = mGeometry.calculate(model);
+        if (layout.viewportOffsetClamped) {
+            model.viewportOffsetDp = layout.viewportOffsetDp;
+            WorkspaceModelStore.save(mContext, model);
+        }
+
+        AutoTaskStackTransaction taskTransaction = new AutoTaskStackTransaction();
+        boolean hasTaskChanges = false;
+        Set<String> activeIds = new HashSet<>();
+
+        for (WorkspaceGeometry.PanelLayout panelLayout : layout.panels) {
+            WorkspaceModelStore.PanelRecord panel = panelLayout.record;
+            mPanelStateController.ensureTaskPanelState(panel.id);
+            mPanelStateController.ensureHeaderDecorState(panel.id);
+
+            activeIds.add(panel.id);
+            activeIds.add(panelLayout.headerId);
+            if (updateTaskPanelStates) {
+                hasTaskChanges |= mPanelStateController.updateTaskPanel(panel.id,
+                        panelLayout.panelBounds, taskTransaction, /* visible= */ true,
+                        commitTaskStackTransition);
+            }
+            mPanelStateController.updateDecorPanel(panelLayout.headerId, panelLayout.headerBounds,
+                    640, true);
+            if (commitTaskStackTransition) {
+                mTaskRouter.applyRoleAndMaybeLaunch(panel, relaunchChangedPanels);
+            }
+
+            if (panelLayout.gripId != null && panelLayout.gripBounds != null) {
+                mPanelStateController.ensureGripDecorState(panel.id);
+                activeIds.add(panelLayout.gripId);
+                mPanelStateController.updateDecorPanel(panelLayout.gripId,
+                        panelLayout.gripBounds, 650, true);
+            }
+        }
+
+        mPanelStateController.updateDecorPanel(WorkspaceConstants.TOOLBAR_PANEL_ID,
+                layout.toolbarBounds, 720, true);
+        activeIds.add(WorkspaceConstants.TOOLBAR_PANEL_ID);
+
+        mPanelStateController.updateDecorPanel(WorkspaceConstants.VIEWPORT_PANEL_ID,
+                layout.viewportBounds, 720, layout.viewportVisible);
+        activeIds.add(WorkspaceConstants.VIEWPORT_PANEL_ID);
+
+        if (updateTaskPanelStates) {
+            mPanelStateController.hideInactiveDynamicPanels(activeIds, taskTransaction);
+        }
+        mPanelStateController.updateSurfaceStates(activeIds, includeTaskSurfaces,
+                /* includeKnownDecorPanels= */ true);
+        if (commitTaskStackTransition && hasTaskChanges) {
+            mAutoTaskStackController.startTransition(taskTransaction);
+        }
+        if (structureOrUiChanged) {
+            mPanelStateController.resetDecorPanels(activeIds);
+        }
+    }
+
+    private void updateResizePreview(WorkspaceModelStore.Model model, String leftPanelId) {
+        WorkspaceGeometry.PanelLayout panelLayout = mGeometry.calculate(model).panelById(leftPanelId);
+        if (panelLayout == null || panelLayout.gripId == null || panelLayout.gripBounds == null) {
+            return;
+        }
+        mPanelStateController.ensureGripDecorState(leftPanelId);
+        mPanelStateController.updateDecorPanel(panelLayout.gripId, panelLayout.gripBounds,
+                650, true);
+        Set<String> previewIds = new HashSet<>();
+        previewIds.add(panelLayout.gripId);
+        mPanelStateController.updateSurfaceStates(previewIds, /* includeTaskPanels= */ false,
+                /* includeKnownDecorPanels= */ false);
+    }
+
+    private void clampViewport(WorkspaceModelStore.Model model) {
+        model.viewportOffsetDp = Math.max(0, model.viewportOffsetDp);
+    }
+
+    private int indexOf(WorkspaceModelStore.Model model, String panelId) {
+        for (int i = 0; i < model.panels.size(); i++) {
+            if (panelId.equals(model.panels.get(i).id)) {
+                return i;
+            }
+        }
+        return -1;
+    }
+
+    private boolean isWorkspaceProduct() {
+        return WorkspaceConstants.PRODUCT_NAME.equals(Build.PRODUCT)
+                || WorkspaceConstants.PRODUCT_NAME.equals(
+                        SystemProperties.get("ro.product.name", ""))
+                || WorkspaceConstants.PRODUCT_NAME.equals(
+                        SystemProperties.get("ro.product.product.name", ""));
+    }
+
+    private static final class DragState {
+        final String panelId;
+        final int startIndex;
+
+        DragState(String panelId, int startIndex) {
+            this.panelId = panelId;
+            this.startIndex = startIndex;
+        }
+
+        void resetThreshold() {
+        }
+    }
+
+    private static final class ResizeDragState {
+        final String leftPanelId;
+        final int startLeftWidthDp;
+        final int startRightWidthDp;
+
+        ResizeDragState(String leftPanelId, int startLeftWidthDp, int startRightWidthDp) {
+            this.leftPanelId = leftPanelId;
+            this.startLeftWidthDp = startLeftWidthDp;
+            this.startRightWidthDp = startRightWidthDp;
+        }
+    }
+
+    private static final class PanDragState {
+        final int startViewportDp;
+
+        PanDragState(int startViewportDp) {
+            this.startViewportDp = startViewportDp;
+        }
+    }
+}
