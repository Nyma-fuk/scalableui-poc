diff --git a/src/com/android/systemui/car/wm/scalableui/workspace/WorkspaceGeometry.java b/src/com/android/systemui/car/wm/scalableui/workspace/WorkspaceGeometry.java
new file mode 100644
index 0000000000000000000000000000000000000000..7a81bee776bd6fa1385a07d9913505ad08a654bd
--- /dev/null
+++ b/src/com/android/systemui/car/wm/scalableui/workspace/WorkspaceGeometry.java
@@ -0,0 +1,212 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.Context;
+import android.graphics.Rect;
+
+import androidx.annotation.Nullable;
+
+import com.android.systemui.R;
+
+import java.util.ArrayList;
+import java.util.List;
+
+final class WorkspaceGeometry {
+    private static final int TOOLBAR_HEIGHT_DP = 72;
+    private static final int VIEWPORT_HEIGHT_DP = 92;
+    private static final int WORKSPACE_TOP_PADDING_DP = 24;
+    private static final int WORKSPACE_BOTTOM_PADDING_DP = 20;
+    private static final int PANEL_HEIGHT_MARGIN_DP = 12;
+    private static final int PANEL_GAP_DP = 20;
+    private static final int PANEL_MIN_WIDTH_DP = 280;
+    private static final int HEADER_HEIGHT_DP = 68;
+    private static final int HEADER_MARGIN_DP = 12;
+    private static final int GRIP_WIDTH_DP = 40;
+    private static final int VIEWPORT_SIDE_MARGIN_DP = 32;
+
+    private final Context mContext;
+
+    WorkspaceGeometry(Context context) {
+        mContext = context;
+    }
+
+    Layout calculate(WorkspaceModelStore.Model model) {
+        Rect displayBounds = getDisplayBounds();
+        Rect stripBounds = getWorkspaceStripBounds(displayBounds);
+        int gapPx = dpToPx(PANEL_GAP_DP);
+        int headerHeightPx = dpToPx(HEADER_HEIGHT_DP);
+        int headerMarginPx = dpToPx(HEADER_MARGIN_DP);
+        int gripWidthPx = dpToPx(GRIP_WIDTH_DP);
+        int totalContentWidthPx = getTotalContentWidthPx(model, gapPx);
+
+        int viewportOffsetPx = dpToPx(model.viewportOffsetDp);
+        int maxViewportPx = Math.max(0, totalContentWidthPx - stripBounds.width());
+        int clampedViewportOffsetPx = Math.min(Math.max(0, viewportOffsetPx), maxViewportPx);
+        int clampedViewportOffsetDp = pxToDp(clampedViewportOffsetPx);
+
+        ArrayList<PanelLayout> panelLayouts = new ArrayList<>();
+        int cursorX = stripBounds.left - clampedViewportOffsetPx;
+        for (int i = 0; i < model.panels.size(); i++) {
+            WorkspaceModelStore.PanelRecord panel = model.panels.get(i);
+            int panelWidthPx = dpToPx(panel.widthDp);
+            Rect panelBounds = new Rect(cursorX, stripBounds.top,
+                    cursorX + panelWidthPx, stripBounds.bottom);
+            Rect headerBounds = new Rect(
+                    panelBounds.left + headerMarginPx,
+                    panelBounds.top + headerMarginPx,
+                    panelBounds.right - headerMarginPx,
+                    Math.min(panelBounds.bottom - headerMarginPx,
+                            panelBounds.top + headerMarginPx + headerHeightPx));
+
+            Rect gripBounds = null;
+            String gripId = null;
+            if (i < model.panels.size() - 1) {
+                gripId = gripPanelId(panel.id);
+                gripBounds = new Rect(
+                        panelBounds.right + (gapPx / 2) - (gripWidthPx / 2),
+                        stripBounds.top,
+                        panelBounds.right + (gapPx / 2) + (gripWidthPx / 2),
+                        stripBounds.bottom);
+            }
+
+            panelLayouts.add(new PanelLayout(panel, panelBounds, headerPanelId(panel.id),
+                    headerBounds, gripId, gripBounds));
+            cursorX = panelBounds.right + gapPx;
+        }
+
+        Rect toolbarBounds = new Rect(
+                displayBounds.left,
+                displayBounds.top + getTopSystemBarHeight(),
+                displayBounds.right,
+                displayBounds.top + getTopSystemBarHeight() + dpToPx(TOOLBAR_HEIGHT_DP));
+        Rect viewportBounds = new Rect(
+                displayBounds.left + dpToPx(VIEWPORT_SIDE_MARGIN_DP),
+                displayBounds.bottom - getBottomSystemBarHeight() - dpToPx(VIEWPORT_HEIGHT_DP),
+                displayBounds.right - dpToPx(VIEWPORT_SIDE_MARGIN_DP),
+                displayBounds.bottom - getBottomSystemBarHeight());
+        boolean viewportVisible = model.panels.size() > 1
+                && totalContentWidthPx > stripBounds.width();
+
+        return new Layout(displayBounds, stripBounds, toolbarBounds, viewportBounds,
+                viewportVisible, totalContentWidthPx, clampedViewportOffsetDp,
+                clampedViewportOffsetDp != model.viewportOffsetDp, panelLayouts);
+    }
+
+    int clampWidth(int widthDp) {
+        return Math.max(PANEL_MIN_WIDTH_DP, widthDp);
+    }
+
+    int dpToPx(int valueDp) {
+        return Math.round(valueDp * mContext.getResources().getDisplayMetrics().density);
+    }
+
+    static String headerPanelId(String panelId) {
+        return "decor_workspace_header_" + panelId;
+    }
+
+    static String gripPanelId(String leftPanelId) {
+        return "decor_workspace_grip_" + leftPanelId;
+    }
+
+    static Rect offscreenBounds() {
+        return new Rect(-4000, -4000, -3600, -3600);
+    }
+
+    private int getTotalContentWidthPx(WorkspaceModelStore.Model model, int gapPx) {
+        int totalContentWidthPx = 0;
+        for (int i = 0; i < model.panels.size(); i++) {
+            totalContentWidthPx += dpToPx(model.panels.get(i).widthDp);
+            if (i < model.panels.size() - 1) {
+                totalContentWidthPx += gapPx;
+            }
+        }
+        return totalContentWidthPx;
+    }
+
+    private Rect getDisplayBounds() {
+        return new Rect(0, 0,
+                mContext.getResources().getDisplayMetrics().widthPixels,
+                mContext.getResources().getDisplayMetrics().heightPixels);
+    }
+
+    private Rect getWorkspaceStripBounds(Rect displayBounds) {
+        int top = getTopSystemBarHeight() + dpToPx(TOOLBAR_HEIGHT_DP)
+                + dpToPx(WORKSPACE_TOP_PADDING_DP);
+        int bottom = displayBounds.bottom - getBottomSystemBarHeight()
+                - dpToPx(VIEWPORT_HEIGHT_DP) - dpToPx(WORKSPACE_BOTTOM_PADDING_DP);
+        return new Rect(
+                displayBounds.left + dpToPx(24),
+                top,
+                displayBounds.right - dpToPx(24),
+                Math.max(top + dpToPx(240), bottom - dpToPx(PANEL_HEIGHT_MARGIN_DP)));
+    }
+
+    private int getTopSystemBarHeight() {
+        return mContext.getResources().getDimensionPixelSize(R.dimen.car_top_system_bar_height);
+    }
+
+    private int getBottomSystemBarHeight() {
+        return mContext.getResources().getDimensionPixelSize(
+                R.dimen.car_bottom_system_bar_height);
+    }
+
+    private int pxToDp(int valuePx) {
+        return Math.round(valuePx / mContext.getResources().getDisplayMetrics().density);
+    }
+
+    static final class Layout {
+        final Rect displayBounds;
+        final Rect stripBounds;
+        final Rect toolbarBounds;
+        final Rect viewportBounds;
+        final boolean viewportVisible;
+        final int totalContentWidthPx;
+        final int viewportOffsetDp;
+        final boolean viewportOffsetClamped;
+        final List<PanelLayout> panels;
+
+        Layout(Rect displayBounds, Rect stripBounds, Rect toolbarBounds, Rect viewportBounds,
+                boolean viewportVisible, int totalContentWidthPx, int viewportOffsetDp,
+                boolean viewportOffsetClamped, List<PanelLayout> panels) {
+            this.displayBounds = displayBounds;
+            this.stripBounds = stripBounds;
+            this.toolbarBounds = toolbarBounds;
+            this.viewportBounds = viewportBounds;
+            this.viewportVisible = viewportVisible;
+            this.totalContentWidthPx = totalContentWidthPx;
+            this.viewportOffsetDp = viewportOffsetDp;
+            this.viewportOffsetClamped = viewportOffsetClamped;
+            this.panels = panels;
+        }
+
+        @Nullable
+        PanelLayout panelById(String panelId) {
+            for (PanelLayout panel : panels) {
+                if (panel.record.id.equals(panelId)) {
+                    return panel;
+                }
+            }
+            return null;
+        }
+    }
+
+    static final class PanelLayout {
+        final WorkspaceModelStore.PanelRecord record;
+        final Rect panelBounds;
+        final String headerId;
+        final Rect headerBounds;
+        @Nullable
+        final String gripId;
+        @Nullable
+        final Rect gripBounds;
+
+        PanelLayout(WorkspaceModelStore.PanelRecord record, Rect panelBounds, String headerId,
+                Rect headerBounds, @Nullable String gripId, @Nullable Rect gripBounds) {
+            this.record = record;
+            this.panelBounds = panelBounds;
+            this.headerId = headerId;
+            this.headerBounds = headerBounds;
+            this.gripId = gripId;
+            this.gripBounds = gripBounds;
+        }
+    }
+}
