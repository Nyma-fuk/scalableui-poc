+                for (ActivityManager.RunningTaskInfo taskInfo : mPanelTaskMap.get(panelId).values()) {
+                    if (taskInfo.taskId == excludedTaskId
+                            || taskInfo.displayId != displayId
+                            || !isTaskReusable(taskInfo)
+                            || !matchesComponent(taskInfo, componentName)) {
