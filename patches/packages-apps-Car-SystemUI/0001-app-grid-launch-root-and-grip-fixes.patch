+package com.android.systemui.car.wm.scalableui;
+
+import android.content.Context;
+import android.graphics.Rect;
+import android.os.Build;
+import android.os.SystemProperties;
+import android.util.DisplayMetrics;
+import android.util.Log;
+import android.view.SurfaceControl;
+
+import com.android.car.scalableui.manager.StateManager;
+import com.android.car.scalableui.model.Event;
+import com.android.car.scalableui.model.KeyFrameEvent;
+import com.android.car.scalableui.model.PanelState;
+import com.android.car.scalableui.model.Variant;
+import com.android.systemui.R;
+import com.android.systemui.car.wm.scalableui.panel.BasePanel;
+import com.android.systemui.car.wm.scalableui.panel.PanelUtils;
+import com.android.systemui.car.wm.scalableui.panel.TaskPanel;
+import com.android.wm.shell.automotive.AutoSurfaceTransaction;
+import com.android.wm.shell.automotive.AutoSurfaceTransactionFactory;
+import com.android.wm.shell.automotive.AutoTaskStackController;
+import com.android.wm.shell.automotive.AutoTaskStackState;
+import com.android.wm.shell.automotive.AutoTaskStackTransaction;
+import com.android.wm.shell.common.ShellExecutor;
+import com.android.wm.shell.dagger.WMSingleton;
+import com.android.wm.shell.shared.annotations.ShellMainThread;
+
+import javax.inject.Inject;
+
+/**
+ * Applies deterministic split-layout updates for the small-start ScalableUI PoC product.
+ *
+ * <p>The root PoC uses three fixed task panels and two grip decor panels. The original
+ * XML transition path is good enough for initial rendering, but width drag updates have proven
+ * flaky on emulator. This controller keeps one runtime width ratio and one runtime height ratio
+ * and updates the task stacks and decor surfaces directly when grip events arrive.
+ */
+@WMSingleton
+public class ScalableUiPocRuntimeLayoutController {
+    private static final String TAG = "ScalableUiPocLayout";
+    private static final boolean DEBUG = Build.IS_DEBUGGABLE;
+
+    private static final String PRODUCT_NAME = "sdk_car_scalableui_x86_64";
+
+    private static final String PANEL_LEFT_BACKGROUND = "decor_left_background_panel";
+    private static final String PANEL_MAP = "map_panel";
+    private static final String PANEL_CALENDAR = "calendar_panel";
+    private static final String PANEL_RADIO = "radio_panel";
+    private static final String PANEL_VERTICAL_GRIP = "decor_vertical_grip_panel";
+    private static final String PANEL_HORIZONTAL_GRIP = "decor_horizontal_grip_panel";
+
+    private static final String EVENT_WIDTH_DRAG = "layout_width_drag";
+    private static final String EVENT_WIDTH_NARROW = "layout_width_left_narrow";
+    private static final String EVENT_WIDTH_BALANCED = "layout_width_balanced";
+    private static final String EVENT_WIDTH_WIDE = "layout_width_left_wide";
+    private static final String EVENT_HEIGHT_DRAG = "layout_height_drag";
+    private static final String EVENT_HEIGHT_COMPACT = "layout_height_map_compact";
+    private static final String EVENT_HEIGHT_BALANCED = "layout_height_balanced";
+    private static final String EVENT_HEIGHT_TALL = "layout_height_map_tall";
+
+    private static final float WIDTH_NARROW_RATIO = 0.40f;
+    private static final float WIDTH_BALANCED_RATIO = 0.50f;
+    private static final float WIDTH_WIDE_RATIO = 0.60f;
+    private static final float HEIGHT_COMPACT_RATIO = 0.35f;
+    private static final float HEIGHT_BALANCED_RATIO = 0.50f;
+    private static final float HEIGHT_TALL_RATIO = 0.65f;
+
+    private static final float MAP_MARGIN_DP = 24f;
+    private static final float MAP_SPLIT_GAP_DP = 36f;
+    private static final float RIGHT_PANEL_GAP_DP = 12f;
+    private static final float VERTICAL_GRIP_WIDTH_DP = 48f;
+    private static final float HORIZONTAL_GRIP_HEIGHT_DP = 48f;
+
+    private final Context mContext;
+    private final AutoTaskStackController mAutoTaskStackController;
+    private final AutoSurfaceTransactionFactory mAutoSurfaceTransactionFactory;
+    private final PanelUtils mPanelUtils;
+    private final ShellExecutor mMainExecutor;
+
+    private float mWidthRatio = WIDTH_BALANCED_RATIO;
+    private float mHeightRatio = HEIGHT_BALANCED_RATIO;
+    private float mPendingWidthRatio = WIDTH_BALANCED_RATIO;
+    private float mPendingHeightRatio = HEIGHT_BALANCED_RATIO;
+    private boolean mApplyScheduled;
+
+    @Inject
+    public ScalableUiPocRuntimeLayoutController(
+            Context context,
+            AutoTaskStackController autoTaskStackController,
+            AutoSurfaceTransactionFactory autoSurfaceTransactionFactory,
+            PanelUtils panelUtils,
+            @ShellMainThread ShellExecutor mainExecutor) {
+        mContext = context;
+        mAutoTaskStackController = autoTaskStackController;
+        mAutoSurfaceTransactionFactory = autoSurfaceTransactionFactory;
+        mPanelUtils = panelUtils;
+        mMainExecutor = mainExecutor;
+    }
+
+    /**
+     * Applies the default safe-area-aware layout during startup so root PoC panels do not overlap
+     * the persistent system bars before the first grip interaction.
+     */
+    public void init() {
+        if (!isScalableUiPocProduct()) {
+            return;
+        }
+        scheduleApply(mWidthRatio, mHeightRatio);
+    }
+
+    /**
+     * Returns true when the event was consumed by the fixed three-panel PoC controller.
+     */
+    public boolean handleEvent(Event event) {
+        if (!isScalableUiPocProduct() || event == null) {
+            return false;
+        }
+
+        float newWidthRatio = mWidthRatio;
+        float newHeightRatio = mHeightRatio;
+        boolean handled = false;
+        String eventId = event.getId();
+        if (EVENT_WIDTH_DRAG.equals(eventId) && event instanceof KeyFrameEvent keyFrameEvent) {
+            newWidthRatio = lerp(WIDTH_NARROW_RATIO, WIDTH_WIDE_RATIO,
+                    keyFrameEvent.getFraction());
+            handled = true;
+        } else if (EVENT_WIDTH_NARROW.equals(eventId)) {
+            newWidthRatio = WIDTH_NARROW_RATIO;
+            handled = true;
+        } else if (EVENT_WIDTH_BALANCED.equals(eventId)) {
+            newWidthRatio = WIDTH_BALANCED_RATIO;
+            handled = true;
+        } else if (EVENT_WIDTH_WIDE.equals(eventId)) {
+            newWidthRatio = WIDTH_WIDE_RATIO;
+            handled = true;
+        } else if (EVENT_HEIGHT_DRAG.equals(eventId) && event instanceof KeyFrameEvent keyFrameEvent) {
+            newHeightRatio = lerp(HEIGHT_COMPACT_RATIO, HEIGHT_TALL_RATIO,
+                    keyFrameEvent.getFraction());
+            handled = true;
+        } else if (EVENT_HEIGHT_COMPACT.equals(eventId)) {
+            newHeightRatio = HEIGHT_COMPACT_RATIO;
+            handled = true;
+        } else if (EVENT_HEIGHT_BALANCED.equals(eventId)) {
+            newHeightRatio = HEIGHT_BALANCED_RATIO;
+            handled = true;
+        } else if (EVENT_HEIGHT_TALL.equals(eventId)) {
+            newHeightRatio = HEIGHT_TALL_RATIO;
+            handled = true;
+        }
+
+        if (!handled) {
+            return false;
+        }
+
+        if (approximatelyEqual(mWidthRatio, newWidthRatio)
+                && approximatelyEqual(mHeightRatio, newHeightRatio)) {
+            return true;
+        }
+
+        mWidthRatio = newWidthRatio;
+        mHeightRatio = newHeightRatio;
+        scheduleApply(newWidthRatio, newHeightRatio);
+        return true;
+    }
+
+    private void scheduleApply(float widthRatio, float heightRatio) {
+        mPendingWidthRatio = widthRatio;
+        mPendingHeightRatio = heightRatio;
+        if (mApplyScheduled) {
+            return;
+        }
+        mApplyScheduled = true;
+        mMainExecutor.execute(this::drainPendingApplyOnMain);
+    }
+
+    private void drainPendingApplyOnMain() {
+        float widthRatio = mPendingWidthRatio;
+        float heightRatio = mPendingHeightRatio;
+        mApplyScheduled = false;
+        applyLayoutOnMain(widthRatio, heightRatio);
+        if (!approximatelyEqual(widthRatio, mPendingWidthRatio)
+                || !approximatelyEqual(heightRatio, mPendingHeightRatio)) {
+            scheduleApply(mPendingWidthRatio, mPendingHeightRatio);
+        }
+    }
+
+    private void applyLayoutOnMain(float widthRatio, float heightRatio) {
+        DisplayMetrics metrics = mContext.getResources().getDisplayMetrics();
+        int displayWidth = metrics.widthPixels;
+        int displayHeight = metrics.heightPixels;
+        if (displayWidth <= 0 || displayHeight <= 0) {
+            return;
+        }
+        int contentTop = mContext.getResources().getDimensionPixelSize(
+                R.dimen.car_top_system_bar_height);
+        int contentBottom = displayHeight - mContext.getResources().getDimensionPixelSize(
+                R.dimen.car_bottom_system_bar_height);
+        if (contentBottom <= contentTop) {
+            contentTop = 0;
+            contentBottom = displayHeight;
+        }
+        int contentHeight = contentBottom - contentTop;
+
+        int mapMarginPx = dpToPx(MAP_MARGIN_DP);
+        int mapSplitGapPx = dpToPx(MAP_SPLIT_GAP_DP);
+        int rightPanelGapPx = dpToPx(RIGHT_PANEL_GAP_DP);
+        int verticalGripWidthPx = dpToPx(VERTICAL_GRIP_WIDTH_DP);
+        int horizontalGripHeightPx = dpToPx(HORIZONTAL_GRIP_HEIGHT_DP);
+        int halfVerticalGripWidthPx = verticalGripWidthPx / 2;
+        int halfHorizontalGripHeightPx = horizontalGripHeightPx / 2;
+
+        int splitX = Math.round(displayWidth * widthRatio);
+        int splitY = contentTop + Math.round(contentHeight * heightRatio);
+
+        Rect leftBackgroundBounds = new Rect(0, contentTop, splitX, contentBottom);
+        Rect mapBounds = new Rect(
+                mapMarginPx,
+                contentTop + mapMarginPx,
+                Math.max(mapMarginPx, splitX - mapSplitGapPx),
+                Math.max(contentTop + mapMarginPx, contentBottom - mapMarginPx));
+        Rect calendarBounds = new Rect(
+                splitX + rightPanelGapPx,
+                contentTop,
+                displayWidth,
+                Math.max(contentTop + rightPanelGapPx, splitY - rightPanelGapPx));
+        Rect radioBounds = new Rect(
+                splitX + rightPanelGapPx,
+                splitY + rightPanelGapPx,
+                displayWidth,
+                contentBottom);
+        Rect verticalGripBounds = new Rect(
+                splitX - halfVerticalGripWidthPx,
+                contentTop,
+                splitX + halfVerticalGripWidthPx,
+                contentBottom);
+        Rect horizontalGripBounds = new Rect(
+                splitX + rightPanelGapPx,
+                splitY - halfHorizontalGripHeightPx,
+                displayWidth,
+                splitY + halfHorizontalGripHeightPx);
+
+        AutoTaskStackTransaction transaction = new AutoTaskStackTransaction();
+        boolean hasTaskChanges = false;
+        hasTaskChanges |= updatePanel(PANEL_MAP, mapBounds, transaction);
+        hasTaskChanges |= updatePanel(PANEL_CALENDAR, calendarBounds, transaction);
+        hasTaskChanges |= updatePanel(PANEL_RADIO, radioBounds, transaction);
+        updatePanel(PANEL_LEFT_BACKGROUND, leftBackgroundBounds, null);
+        updatePanel(PANEL_VERTICAL_GRIP, verticalGripBounds, null);
+        updatePanel(PANEL_HORIZONTAL_GRIP, horizontalGripBounds, null);
+
+        updateSurfaceStates(
+                PANEL_LEFT_BACKGROUND,
+                PANEL_MAP,
+                PANEL_CALENDAR,
+                PANEL_RADIO,
+                PANEL_VERTICAL_GRIP,
+                PANEL_HORIZONTAL_GRIP);
+        if (hasTaskChanges) {
+            mAutoTaskStackController.startTransition(transaction);
+        }
+        if (DEBUG) {
+            Log.d(TAG, "Applied root PoC layout widthRatio=" + widthRatio
+                    + " heightRatio=" + heightRatio);
+        }
+    }
+
+    private boolean updatePanel(String panelId, Rect bounds, AutoTaskStackTransaction transaction) {
+        PanelState panelState = StateManager.getPanelState(panelId);
+        if (panelState == null) {
+            return false;
+        }
+        Variant currentVariant = panelState.getCurrentVariant();
+        if (currentVariant == null) {
+            return false;
+        }
+        Rect safeBounds = new Rect(bounds);
+        currentVariant.setRuntimeBounds(bounds);
+        currentVariant.setRuntimeSafeBounds(safeBounds);
+        currentVariant.setRuntimeVisibility(true);
+        StateManager.applyState(panelState);
+
+        if (transaction == null) {
+            return false;
+        }
+        TaskPanel taskPanel = mPanelUtils.getTaskPanel(
+                panel -> panelId.equals(panel.getPanelId()) && panel.getRootStack() != null);
+        if (taskPanel == null) {
+            return false;
+        }
+        AutoTaskStackState taskStackState = new AutoTaskStackState(
+                new Rect(bounds), true, taskPanel.getLayer());
+        transaction.setTaskStackState(taskPanel.getRootStack().getId(), taskStackState);
+        transaction.setSafeRegionBounds(taskPanel.getRootStack().getId(), safeBounds);
+        if (taskPanel.isRootTaskEmpty() && mPanelUtils.isUserUnlocked()) {
+            taskPanel.setBaseIntent(transaction);
+        }
+        return true;
+    }
+
+    private void updateSurfaceStates(String... panelIds) {
+        AutoSurfaceTransaction autoSurfaceTransaction =
+                mAutoSurfaceTransactionFactory.createTransaction("SCALABLE_UI_POC_LAYOUT");
+        SurfaceControl.Transaction tx = new SurfaceControl.Transaction();
+        for (String panelId : panelIds) {
+            BasePanel basePanel = mPanelUtils.getBasePanel(
+                    panel -> panelId.equals(panel.getPanelId()));
+            if (basePanel == null) {
+                continue;
+            }
+            PanelState panelState = StateManager.getPanelState(panelId);
+            Variant currentVariant = panelState == null ? null : panelState.getCurrentVariant();
+            basePanel.update(autoSurfaceTransaction, tx, currentVariant);
+        }
+        tx.apply();
+        autoSurfaceTransaction.apply();
+    }
+
+    private boolean isScalableUiPocProduct() {
+        return PRODUCT_NAME.equals(Build.PRODUCT)
+                || PRODUCT_NAME.equals(SystemProperties.get("ro.product.name", ""))
+                || PRODUCT_NAME.equals(SystemProperties.get("ro.product.product.name", ""));
+    }
+
+    private int dpToPx(float valueDp) {
+        return Math.round(valueDp * mContext.getResources().getDisplayMetrics().density);
+    }
+
+    private static float lerp(float start, float end, float fraction) {
+        return start + ((end - start) * clamp(fraction, 0f, 1f));
+    }
+
+    private static float clamp(float value, float min, float max) {
+        if (Float.isNaN(value)) {
+            return (min + max) / 2f;
+        }
+        return Math.max(min, Math.min(max, value));
+    }
+
+    private static boolean approximatelyEqual(float value1, float value2) {
+        return Math.abs(value1 - value2) < 0.001f;
+    }
+}
