@@ -0,0 +1,159 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.Context;
+import android.content.pm.PackageManager;
+import android.graphics.Color;
+import android.graphics.Typeface;
+import android.graphics.drawable.GradientDrawable;
+import android.text.TextUtils;
+import android.view.MotionEvent;
+import android.view.View;
+import android.widget.Button;
+import android.widget.LinearLayout;
+import android.widget.TextView;
+
+public final class WorkspaceHeaderView extends LinearLayout {
+    private static final long MIN_UPDATE_INTERVAL_MS = 160L;
+    private static final float MIN_UPDATE_DELTA_DP = 24f;
+
+    private final TextView mTitle;
+    private final View mDragHandle;
+    private String mPanelId;
+    private float mDragStartX;
+    private float mLastSentDeltaDp;
+    private long mLastSentUptimeMs;
+
+    public WorkspaceHeaderView(Context context) {
+        super(context);
+        setOrientation(HORIZONTAL);
+        setGravity(android.view.Gravity.CENTER_VERTICAL);
+        int pad = dp(14);
+        setPadding(pad, dp(10), pad, dp(10));
+        GradientDrawable bg = new GradientDrawable();
+        bg.setColor(Color.argb(224, 22, 28, 37));
+        bg.setCornerRadius(dp(24));
+        bg.setStroke(dp(1), Color.argb(70, 255, 255, 255));
+        setBackground(bg);
+
+        mTitle = new TextView(context);
+        mTitle.setTextColor(Color.WHITE);
+        mTitle.setTextSize(14f);
+        mTitle.setTypeface(Typeface.DEFAULT_BOLD);
+        LayoutParams titleParams = new LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f);
+        addView(mTitle, titleParams);
+
+        mDragHandle = new View(context);
+        GradientDrawable handle = new GradientDrawable();
+        handle.setColor(Color.rgb(110, 125, 147));
+        handle.setCornerRadius(dp(8));
+        mDragHandle.setBackground(handle);
+        LayoutParams dragParams = new LayoutParams(dp(24), dp(24));
+        dragParams.rightMargin = dp(10);
+        addView(mDragHandle, dragParams);
+
+        Button app = smallButton(context, "App");
+        app.setOnClickListener(v -> WorkspaceUiBridge.sendCommand(
+                getContext(), WorkspaceConstants.COMMAND_OPEN_PICKER, mPanelId, 0f));
+        addView(app);
+
+        Button close = smallButton(context, "Close");
+        close.setOnClickListener(v -> WorkspaceUiBridge.sendCommand(
+                getContext(), WorkspaceConstants.COMMAND_REMOVE_PANEL, mPanelId, 0f));
+        LayoutParams closeParams = new LayoutParams(
+                LayoutParams.WRAP_CONTENT, LayoutParams.WRAP_CONTENT);
+        closeParams.leftMargin = dp(8);
+        addView(close, closeParams);
+
+        mDragHandle.setOnTouchListener((v, event) -> handleDrag(event));
+    }
+
+    public void bind(String panelId) {
+        mPanelId = panelId;
+        mTitle.setText(resolveLabel(panelId));
+    }
+
+    private boolean handleDrag(MotionEvent event) {
+        if (TextUtils.isEmpty(mPanelId)) {
+            return false;
+        }
+        if (event.getAction() == MotionEvent.ACTION_DOWN) {
+            mDragStartX = event.getRawX();
+            mLastSentDeltaDp = 0f;
+            mLastSentUptimeMs = event.getEventTime();
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_MOVE_START,
+                    mPanelId, 0f);
+            return true;
+        }
+        if (event.getAction() == MotionEvent.ACTION_MOVE) {
+            float deltaDp = pxToDp(event.getRawX() - mDragStartX);
+            if (shouldDispatchUpdate(event, deltaDp)) {
+                WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_MOVE_UPDATE,
+                        mPanelId, deltaDp);
+                mLastSentDeltaDp = deltaDp;
+                mLastSentUptimeMs = event.getEventTime();
+            }
+            return true;
+        }
+        if (event.getAction() == MotionEvent.ACTION_UP
+                || event.getAction() == MotionEvent.ACTION_CANCEL) {
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_MOVE_UPDATE,
+                    mPanelId, pxToDp(event.getRawX() - mDragStartX));
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_MOVE_END,
+                    mPanelId, 0f);
+            return true;
+        }
+        return false;
+    }
+
+    private String resolveLabel(String panelId) {
+        WorkspaceModelStore.Model model = WorkspaceModelStore.load(getContext());
+        for (WorkspaceModelStore.PanelRecord panel : model.panels) {
+            if (!panelId.equals(panel.id)) {
+                continue;
+            }
+            if (WorkspaceConstants.EMPTY_PANEL_COMPONENT.equals(panel.componentName)) {
+                return "Empty panel";
+            }
+            try {
+                android.content.ComponentName cn = android.content.ComponentName
+                        .unflattenFromString(panel.componentName);
+                if (cn != null) {
+                    CharSequence label = getContext().getPackageManager().getActivityInfo(cn, 0)
+                            .loadLabel(getContext().getPackageManager());
+                    if (!TextUtils.isEmpty(label)) {
+                        return label.toString();
+                    }
+                }
+            } catch (PackageManager.NameNotFoundException ignored) {
+            }
+            return panel.componentName;
+        }
+        return panelId;
+    }
+
+    private Button smallButton(Context context, String text) {
+        Button button = new Button(context);
+        button.setAllCaps(false);
+        button.setText(text);
+        button.setTextColor(Color.WHITE);
+        button.setTextSize(12f);
+        GradientDrawable bg = new GradientDrawable();
+        bg.setColor(Color.rgb(52, 67, 88));
+        bg.setCornerRadius(dp(16));
+        button.setBackground(bg);
+        return button;
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+
+    private float pxToDp(float valuePx) {
+        return valuePx / getResources().getDisplayMetrics().density;
+    }
+
+    private boolean shouldDispatchUpdate(MotionEvent event, float deltaDp) {
+        return event.getEventTime() - mLastSentUptimeMs >= MIN_UPDATE_INTERVAL_MS
+                && Math.abs(deltaDp - mLastSentDeltaDp) >= MIN_UPDATE_DELTA_DP;
+    }
+}
