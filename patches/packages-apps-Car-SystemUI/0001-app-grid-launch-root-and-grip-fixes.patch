+@WMSingleton
+public class EditableHomeRuntimeLayoutController {
+    private static final String TAG = "EditableHomeLayout";
+    private static final boolean DEBUG = Build.IS_DEBUGGABLE;
+
+    private static final String PRODUCT_NAME = "sdk_car_scalableui_editable_home_x86_64";
+
+    private static final String PANEL_PRIMARY = "home_panel_primary";
+    private static final String PANEL_SECONDARY_TOP = "home_panel_secondary_top";
+    private static final String PANEL_SECONDARY_BOTTOM = "home_panel_secondary_bottom";
+    private static final String HEADER_PRIMARY = "home_panel_primary_header";
+    private static final String HEADER_SECONDARY_TOP = "home_panel_secondary_top_header";
+    private static final String HEADER_SECONDARY_BOTTOM = "home_panel_secondary_bottom_header";
+    private static final String VERTICAL_GRIP = "home_split_vertical_grip";
+    private static final String HORIZONTAL_GRIP = "home_split_horizontal_grip";
+
+    private static final float CONTENT_LEFT_RATIO = 0.04f;
+    private static final float CONTENT_TOP_RATIO = 0.12f;
+    private static final float CONTENT_RIGHT_RATIO = 0.96f;
+    private static final float CONTENT_BOTTOM_RATIO = 0.84f;
+
+    private static final float MIN_PRIMARY_WIDTH_DP = 260f;
+    private static final float MIN_RIGHT_COLUMN_WIDTH_DP = 260f;
+    private static final float MIN_RIGHT_PANEL_HEIGHT_DP = 170f;
+    private static final float PANEL_GAP_DP = 12f;
+    private static final float HEADER_HEIGHT_DP = 52f;
+    private static final float HEADER_MARGIN_DP = 10f;
+    private static final float GRIP_THICKNESS_DP = 48f;
+
+    private final Context mContext;
+    private final AutoTaskStackController mAutoTaskStackController;
+    private final AutoSurfaceTransactionFactory mAutoSurfaceTransactionFactory;
+    private final PanelUtils mPanelUtils;
+    private final ShellExecutor mMainExecutor;
+
+    @Inject
+    public EditableHomeRuntimeLayoutController(Context context,
+            AutoTaskStackController autoTaskStackController,
+            AutoSurfaceTransactionFactory autoSurfaceTransactionFactory,
+            PanelUtils panelUtils,
+            @ShellMainThread ShellExecutor mainExecutor) {
+        mContext = context;
+        mAutoTaskStackController = autoTaskStackController;
+        mAutoSurfaceTransactionFactory = autoSurfaceTransactionFactory;
+        mPanelUtils = panelUtils;
+        mMainExecutor = mainExecutor;
+    }
