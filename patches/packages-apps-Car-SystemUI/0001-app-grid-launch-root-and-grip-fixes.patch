@@ -0,0 +1,76 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.Context;
+import android.graphics.Color;
+import android.graphics.drawable.GradientDrawable;
+import android.widget.Button;
+import android.widget.LinearLayout;
+import android.widget.TextView;
+
+public final class WorkspaceToolbarView extends LinearLayout {
+    public WorkspaceToolbarView(Context context) {
+        super(context);
+        setOrientation(HORIZONTAL);
+        setGravity(android.view.Gravity.CENTER_VERTICAL);
+        int pad = dp(16);
+        setPadding(pad, dp(10), pad, dp(10));
+        GradientDrawable bg = new GradientDrawable();
+        bg.setColor(Color.argb(230, 24, 31, 41));
+        bg.setCornerRadius(dp(28));
+        bg.setStroke(dp(1), Color.argb(70, 255, 255, 255));
+        setBackground(bg);
+
+        TextView title = new TextView(context);
+        title.setText("Dynamic Workspace");
+        title.setTextColor(Color.WHITE);
+        title.setTextSize(18f);
+        title.setTypeface(android.graphics.Typeface.DEFAULT_BOLD);
+        LayoutParams titleParams = new LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f);
+        addView(title, titleParams);
+
+        Button center = tonalButton(context, "Center");
+        center.setOnClickListener(v -> WorkspaceUiBridge.sendCommand(
+                getContext(), WorkspaceConstants.COMMAND_CENTER_VIEW, null, 0f));
+        addView(center);
+
+        Button add = filledButton(context, "Add panel");
+        add.setOnClickListener(v -> WorkspaceUiBridge.sendCommand(
+                getContext(), WorkspaceConstants.COMMAND_ADD_PANEL, null, 0f));
+        LayoutParams addParams = new LayoutParams(
+                LayoutParams.WRAP_CONTENT, LayoutParams.WRAP_CONTENT);
+        addParams.leftMargin = dp(10);
+        addView(add, addParams);
+    }
+
+    private static Button tonalButton(Context context, String text) {
+        Button button = new Button(context);
+        button.setText(text);
+        button.setAllCaps(false);
+        button.setTextColor(Color.WHITE);
+        GradientDrawable bg = new GradientDrawable();
+        bg.setColor(Color.rgb(49, 63, 82));
+        bg.setCornerRadius(dp(context, 20));
+        button.setBackground(bg);
+        return button;
+    }
+
+    private static Button filledButton(Context context, String text) {
+        Button button = new Button(context);
+        button.setText(text);
+        button.setAllCaps(false);
+        button.setTextColor(Color.BLACK);
+        GradientDrawable bg = new GradientDrawable();
+        bg.setColor(Color.rgb(161, 227, 183));
+        bg.setCornerRadius(dp(context, 20));
+        button.setBackground(bg);
+        return button;
+    }
+
+    private int dp(int value) {
+        return dp(getContext(), value);
+    }
+
+    private static int dp(Context context, int value) {
+        return Math.round(value * context.getResources().getDisplayMetrics().density);
+    }
+}
