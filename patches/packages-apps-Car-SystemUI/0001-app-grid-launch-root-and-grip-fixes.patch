@@ -0,0 +1,23 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.Context;
+import android.content.Intent;
+
+final class WorkspaceUiBridge {
+    private WorkspaceUiBridge() {}
+
+    static void sendCommand(Context context, String command, String panelId, float deltaDp) {
+        Intent intent = new Intent(WorkspaceConstants.ACTION_WORKSPACE_COMMAND);
+        intent.putExtra(WorkspaceConstants.EXTRA_COMMAND, command);
+        if (panelId != null) {
+            intent.putExtra(WorkspaceConstants.EXTRA_PANEL_ID, panelId);
+        }
+        intent.putExtra(WorkspaceConstants.EXTRA_DELTA_DP, deltaDp);
+        intent.setPackage("com.android.systemui");
+        context.sendBroadcast(intent);
+    }
+
+    static void launchPicker(Context context, String panelId) {
+        sendCommand(context, WorkspaceConstants.COMMAND_OPEN_PICKER, panelId, 0f);
+    }
+}
