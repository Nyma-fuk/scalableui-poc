+                Math.round(metrics.heightPixels * CONTENT_TOP_RATIO),
+                Math.round(metrics.widthPixels * CONTENT_RIGHT_RATIO),
+                Math.round(metrics.heightPixels * CONTENT_BOTTOM_RATIO));
+        if (contentBounds.width() <= 0 || contentBounds.height() <= 0) {
+            return;
+        }
+
+        int gapPx = dpToPx(PANEL_GAP_DP);
+        int halfGapPx = gapPx / 2;
+        int gripPx = dpToPx(GRIP_THICKNESS_DP);
+        int headerHeightPx = dpToPx(HEADER_HEIGHT_DP);
+        int headerMarginPx = dpToPx(HEADER_MARGIN_DP);
+        int minPrimaryWidthPx = dpToPx(MIN_PRIMARY_WIDTH_DP);
+        int minRightWidthPx = dpToPx(MIN_RIGHT_COLUMN_WIDTH_DP);
+        int minRightHeightPx = dpToPx(MIN_RIGHT_PANEL_HEIGHT_DP);
+
+        int splitX = contentBounds.left + Math.round(clamp(
+                splitRatioX,
+                minPrimaryWidthPx / (float) contentBounds.width(),
+                1f - (minRightWidthPx / (float) contentBounds.width()))
+                * contentBounds.width());
+        int splitY = contentBounds.top + Math.round(clamp(
+                splitRatioRightY,
+                minRightHeightPx / (float) contentBounds.height(),
+                1f - (minRightHeightPx / (float) contentBounds.height()))
+                * contentBounds.height());
+
+        Rect primaryBounds = new Rect(
+                contentBounds.left,
+                contentBounds.top,
+                splitX - halfGapPx,
+                contentBounds.bottom);
+        Rect secondaryTopBounds = new Rect(
+                splitX + halfGapPx,
+                contentBounds.top,
+                contentBounds.right,
+                splitY - halfGapPx);
+        Rect secondaryBottomBounds = new Rect(
+                splitX + halfGapPx,
+                splitY + halfGapPx,
+                contentBounds.right,
+                contentBounds.bottom);
+
+        Rect primaryHeaderBounds = new Rect(
+                primaryBounds.left + headerMarginPx,
+                primaryBounds.top + headerMarginPx,
+                primaryBounds.right - headerMarginPx,
+                Math.min(primaryBounds.bottom - headerMarginPx,
+                        primaryBounds.top + headerMarginPx + headerHeightPx));
+        Rect secondaryTopHeaderBounds = new Rect(
+                secondaryTopBounds.left + headerMarginPx,
+                secondaryTopBounds.top + headerMarginPx,
+                secondaryTopBounds.right - headerMarginPx,
+                Math.min(secondaryTopBounds.bottom - headerMarginPx,
+                        secondaryTopBounds.top + headerMarginPx + headerHeightPx));
+        Rect secondaryBottomHeaderBounds = new Rect(
+                secondaryBottomBounds.left + headerMarginPx,
+                secondaryBottomBounds.top + headerMarginPx,
+                secondaryBottomBounds.right - headerMarginPx,
+                Math.min(secondaryBottomBounds.bottom - headerMarginPx,
+                        secondaryBottomBounds.top + headerMarginPx + headerHeightPx));
+
+        Rect verticalGripBounds = new Rect(
+                splitX - (gripPx / 2),
+                contentBounds.top,
+                splitX + (gripPx / 2),
+                contentBounds.bottom);
+        Rect horizontalGripBounds = new Rect(
+                secondaryTopBounds.left,
+                splitY - (gripPx / 2),
+                secondaryTopBounds.right,
+                splitY + (gripPx / 2));
+
+        AutoTaskStackTransaction transaction = new AutoTaskStackTransaction();
+        boolean hasTaskStackChange = false;
+        hasTaskStackChange |= updatePanel(PANEL_PRIMARY, primaryBounds, transaction);
+        hasTaskStackChange |= updatePanel(PANEL_SECONDARY_TOP, secondaryTopBounds, transaction);
+        hasTaskStackChange |= updatePanel(PANEL_SECONDARY_BOTTOM, secondaryBottomBounds, transaction);
+        hasTaskStackChange |= updatePanel(HEADER_PRIMARY, primaryHeaderBounds, transaction);
+        hasTaskStackChange |= updatePanel(HEADER_SECONDARY_TOP, secondaryTopHeaderBounds, transaction);
+        hasTaskStackChange |= updatePanel(HEADER_SECONDARY_BOTTOM, secondaryBottomHeaderBounds, transaction);
+        hasTaskStackChange |= updatePanel(VERTICAL_GRIP, verticalGripBounds, transaction);
+        hasTaskStackChange |= updatePanel(HORIZONTAL_GRIP, horizontalGripBounds, transaction);
+        updateSurfaceStates(
+                PANEL_PRIMARY,
+                PANEL_SECONDARY_TOP,
+                PANEL_SECONDARY_BOTTOM,
+                HEADER_PRIMARY,
+                HEADER_SECONDARY_TOP,
+                HEADER_SECONDARY_BOTTOM,
+                VERTICAL_GRIP,
+                HORIZONTAL_GRIP);
+        if (hasTaskStackChange) {
+            mAutoTaskStackController.startTransition(transaction);
+        }
+    }
+
+    private boolean updatePanel(String panelId, Rect bounds, AutoTaskStackTransaction transaction) {
+        PanelState panelState = StateManager.getPanelState(panelId);
+        if (panelState == null) {
+            return false;
+        }
+        Variant variant = panelState.getCurrentVariant();
+        if (variant == null) {
+            return false;
+        }
+        Rect safeBounds = new Rect(bounds);
+        variant.setRuntimeBounds(bounds);
+        variant.setRuntimeSafeBounds(safeBounds);
+        variant.setRuntimeVisibility(true);
+        StateManager.applyState(panelState);
+
+        TaskPanel taskPanel = mPanelUtils.getTaskPanel(
+                panel -> panelId.equals(panel.getPanelId()) && panel.getRootStack() != null);
+        if (taskPanel == null) {
+            return false;
+        }
+        AutoTaskStackState state = new AutoTaskStackState(new Rect(bounds), true, taskPanel.getLayer());
+        transaction.setTaskStackState(taskPanel.getRootStack().getId(), state);
+        transaction.setSafeRegionBounds(taskPanel.getRootStack().getId(), safeBounds);
+        if (taskPanel.isRootTaskEmpty() && mPanelUtils.isUserUnlocked()) {
+            taskPanel.setBaseIntent(transaction);
+        }
+        return true;
+    }
+
+    private void updateSurfaceStates(String... panelIds) {
+        AutoSurfaceTransaction autoSurfaceTransaction =
+                mAutoSurfaceTransactionFactory.createTransaction("EDITABLE_HOME_LAYOUT");
+        SurfaceControl.Transaction tx = new SurfaceControl.Transaction();
+        for (String panelId : panelIds) {
+            BasePanel basePanel = mPanelUtils.getBasePanel(panel -> panelId.equals(panel.getPanelId()));
+            if (basePanel == null) {
+                continue;
+            }
+            PanelState panelState = StateManager.getPanelState(panelId);
+            Variant currentVariant = panelState == null ? null : panelState.getCurrentVariant();
+            basePanel.update(autoSurfaceTransaction, tx, currentVariant);
+        }
+        tx.apply();
+        autoSurfaceTransaction.apply();
+        if (DEBUG) {
+            Log.d(TAG, "Applied editable-home runtime layout");
+        }
+    }
+
+    private boolean isEditableHomeProduct() {
+        return PRODUCT_NAME.equals(Build.PRODUCT)
+                || PRODUCT_NAME.equals(SystemProperties.get("ro.product.name", ""))
+                || PRODUCT_NAME.equals(SystemProperties.get("ro.product.product.name", ""));
+    }
+
+    private int dpToPx(float valueDp) {
+        return Math.round(valueDp * mContext.getResources().getDisplayMetrics().density);
+    }
+
+    private static float clamp(float value, float min, float max) {
+        if (Float.isNaN(value)) {
+            return (min + max) / 2f;
+        }
+        if (value < min) {
+            return min;
+        }
+        if (value > max) {
+            return max;
+        }
+        return value;
+    }
+}
