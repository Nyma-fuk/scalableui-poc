@@ -0,0 +1,74 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.app.ActivityManager;
+import android.content.ComponentName;
+import android.content.Context;
+import android.content.Intent;
+import android.net.Uri;
+import android.os.UserHandle;
+
+import com.android.car.scalableui.model.Role;
+import com.android.systemui.car.wm.scalableui.panel.PanelUtils;
+import com.android.systemui.car.wm.scalableui.panel.TaskPanel;
+
+import java.util.HashMap;
+import java.util.Map;
+
+final class WorkspaceTaskRouter {
+    private static final String TARGET_PANEL_EXTRA =
+            "com.android.car.scalableui.extra.TARGET_PANEL_ID";
+    private static final String TARGET_PANEL_URI_SCHEME = "scalableui-hmi";
+    private static final String TARGET_PANEL_URI_HOST = "panel-launch";
+    private static final String TARGET_PANEL_URI_PARAM = "target_panel";
+
+    private final Context mContext;
+    private final PanelUtils mPanelUtils;
+    private final Map<String, String> mLastAssignedComponents = new HashMap<>();
+
+    WorkspaceTaskRouter(Context context, PanelUtils panelUtils) {
+        mContext = context;
+        mPanelUtils = panelUtils;
+    }
+
+    void applyRoleAndMaybeLaunch(WorkspaceModelStore.PanelRecord record,
+            boolean relaunchChangedPanels) {
+        TaskPanel taskPanel = mPanelUtils.getTaskPanel(panel -> record.id.equals(
+                panel.getPanelId()));
+        if (taskPanel == null) {
+            return;
+        }
+        taskPanel.setRole(new Role.Builder().addPersistentActivity(record.componentName).build());
+        String previous = mLastAssignedComponents.put(record.id, record.componentName);
+        if (relaunchChangedPanels
+                && (!record.componentName.equals(previous) || taskPanel.isRootTaskEmpty())) {
+            launchToPanel(record.componentName, record.id);
+        }
+    }
+
+    void launchPickerFullscreen(String panelId) {
+        Intent intent = new Intent(Intent.ACTION_MAIN);
+        intent.setComponent(ComponentName.unflattenFromString(
+                "com.android.car.scalableui.hmi.home/.WorkspaceAppPickerActivity"));
+        intent.putExtra(WorkspaceConstants.EXTRA_PANEL_ID, panelId);
+        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK
+                | Intent.FLAG_ACTIVITY_CLEAR_TOP
+                | Intent.FLAG_ACTIVITY_SINGLE_TOP);
+        mContext.startActivityAsUser(intent, UserHandle.of(ActivityManager.getCurrentUser()));
+    }
+
+    private void launchToPanel(String componentString, String panelId) {
+        Intent intent = new Intent(Intent.ACTION_MAIN);
+        intent.setComponent(ComponentName.unflattenFromString(componentString));
+        intent.putExtra(TARGET_PANEL_EXTRA, panelId);
+        intent.putExtra(WorkspaceConstants.EXTRA_PANEL_ID, panelId);
+        intent.setData(new Uri.Builder()
+                .scheme(TARGET_PANEL_URI_SCHEME)
+                .authority(TARGET_PANEL_URI_HOST)
+                .appendQueryParameter(TARGET_PANEL_URI_PARAM, panelId)
+                .build());
+        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK
+                | Intent.FLAG_ACTIVITY_CLEAR_TOP
+                | Intent.FLAG_ACTIVITY_SINGLE_TOP);
+        mContext.startActivityAsUser(intent, UserHandle.of(ActivityManager.getCurrentUser()));
+    }
+}
