@@ -0,0 +1,72 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.Context;
+import android.graphics.Color;
+import android.graphics.drawable.GradientDrawable;
+import android.text.TextUtils;
+import android.view.MotionEvent;
+import android.widget.FrameLayout;
+import android.widget.TextView;
+
+public final class WorkspaceViewportHandleView extends FrameLayout {
+    private final TextView mLabel;
+    private float mStartX;
+
+    public WorkspaceViewportHandleView(Context context) {
+        super(context);
+        GradientDrawable bg = new GradientDrawable();
+        bg.setColor(Color.argb(228, 18, 24, 32));
+        bg.setCornerRadius(dp(28));
+        bg.setStroke(dp(1), Color.argb(60, 255, 255, 255));
+        setBackground(bg);
+        setPadding(dp(18), dp(16), dp(18), dp(16));
+
+        mLabel = new TextView(context);
+        mLabel.setTextColor(Color.WHITE);
+        mLabel.setTextSize(14f);
+        mLabel.setTypeface(android.graphics.Typeface.DEFAULT_BOLD);
+        addView(mLabel, new LayoutParams(
+                LayoutParams.WRAP_CONTENT, LayoutParams.WRAP_CONTENT,
+                android.view.Gravity.CENTER));
+        refreshLabel();
+        setOnTouchListener((v, event) -> handleTouch(event));
+    }
+
+    public void refreshLabel() {
+        WorkspaceModelStore.Model model = WorkspaceModelStore.load(getContext());
+        if (model.panels.isEmpty()) {
+            mLabel.setText("No panels yet  |  Tap Add panel");
+            return;
+        }
+        mLabel.setText("Panels " + model.panels.size() + "  |  Slide workspace");
+    }
+
+    private boolean handleTouch(MotionEvent event) {
+        if (event.getAction() == MotionEvent.ACTION_DOWN) {
+            mStartX = event.getRawX();
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_PAN_START,
+                    null, 0f);
+            return true;
+        }
+        if (event.getAction() == MotionEvent.ACTION_MOVE) {
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_PAN_UPDATE,
+                    null, pxToDp(event.getRawX() - mStartX));
+            return true;
+        }
+        if (event.getAction() == MotionEvent.ACTION_UP
+                || event.getAction() == MotionEvent.ACTION_CANCEL) {
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_PAN_END,
+                    null, 0f);
+            return true;
+        }
+        return false;
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+
+    private float pxToDp(float valuePx) {
+        return valuePx / getResources().getDisplayMetrics().density;
+    }
+}
