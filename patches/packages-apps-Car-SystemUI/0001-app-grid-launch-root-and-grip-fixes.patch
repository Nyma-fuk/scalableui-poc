@@ -0,0 +1,89 @@
+package com.android.systemui.car.wm.scalableui.workspace;
+
+import android.content.Context;
+import android.graphics.Color;
+import android.graphics.drawable.GradientDrawable;
+import android.view.MotionEvent;
+import android.view.View;
+import android.widget.FrameLayout;
+
+public final class WorkspaceGripView extends FrameLayout {
+    private static final long MIN_UPDATE_INTERVAL_MS = 160L;
+    private static final float MIN_UPDATE_DELTA_DP = 24f;
+
+    private String mLeftPanelId;
+    private float mStartX;
+    private float mLastSentDeltaDp;
+    private long mLastSentUptimeMs;
+
+    public WorkspaceGripView(Context context) {
+        super(context);
+        GradientDrawable bg = new GradientDrawable();
+        bg.setColor(Color.argb(150, 16, 22, 30));
+        bg.setCornerRadius(dp(20));
+        setBackground(bg);
+
+        View rail = new View(context);
+        GradientDrawable railBg = new GradientDrawable();
+        railBg.setColor(Color.rgb(255, 204, 128));
+        railBg.setCornerRadius(dp(5));
+        rail.setBackground(railBg);
+        LayoutParams railParams = new LayoutParams(dp(6), LayoutParams.MATCH_PARENT);
+        railParams.gravity = android.view.Gravity.CENTER;
+        railParams.topMargin = dp(16);
+        railParams.bottomMargin = dp(16);
+        addView(rail, railParams);
+
+        setOnTouchListener((v, event) -> handleTouch(event));
+    }
+
+    public void bind(String leftPanelId) {
+        mLeftPanelId = leftPanelId;
+    }
+
+    private boolean handleTouch(MotionEvent event) {
+        if (mLeftPanelId == null) {
+            return false;
+        }
+        if (event.getAction() == MotionEvent.ACTION_DOWN) {
+            mStartX = event.getRawX();
+            mLastSentDeltaDp = 0f;
+            mLastSentUptimeMs = event.getEventTime();
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_RESIZE_START,
+                    mLeftPanelId, 0f);
+            return true;
+        }
+        if (event.getAction() == MotionEvent.ACTION_MOVE) {
+            float deltaDp = pxToDp(event.getRawX() - mStartX);
+            if (shouldDispatchUpdate(event, deltaDp)) {
+                WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_RESIZE_UPDATE,
+                        mLeftPanelId, deltaDp);
+                mLastSentDeltaDp = deltaDp;
+                mLastSentUptimeMs = event.getEventTime();
+            }
+            return true;
+        }
+        if (event.getAction() == MotionEvent.ACTION_UP
+                || event.getAction() == MotionEvent.ACTION_CANCEL) {
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_RESIZE_UPDATE,
+                    mLeftPanelId, pxToDp(event.getRawX() - mStartX));
+            WorkspaceUiBridge.sendCommand(getContext(), WorkspaceConstants.COMMAND_RESIZE_END,
+                    mLeftPanelId, 0f);
+            return true;
+        }
+        return false;
+    }
+
+    private int dp(int value) {
+        return Math.round(value * getResources().getDisplayMetrics().density);
+    }
+
+    private float pxToDp(float valuePx) {
+        return valuePx / getResources().getDisplayMetrics().density;
+    }
+
+    private boolean shouldDispatchUpdate(MotionEvent event, float deltaDp) {
+        return event.getEventTime() - mLastSentUptimeMs >= MIN_UPDATE_INTERVAL_MS
+                && Math.abs(deltaDp - mLastSentDeltaDp) >= MIN_UPDATE_DELTA_DP;
+    }
+}
