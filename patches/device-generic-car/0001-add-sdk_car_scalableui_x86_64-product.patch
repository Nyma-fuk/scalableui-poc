+# Small-start ScalableUI product for PoC work.
+# Start from the standard emulator car product and layer only the
+# ScalableUI-specific PoC resources on top.
+$(call inherit-product, device/generic/car/sdk_car_x86_64.mk)
+$(call inherit-product, packages/services/Car/car_product/scalableui_poc/car_scalableui_poc.mk)
+
+PRODUCT_NAME := sdk_car_scalableui_x86_64
+PRODUCT_DEVICE := emulator_car64_x86_64
+PRODUCT_BRAND := Android
+PRODUCT_MODEL := Car ScalableUI PoC on x86_64 emulator
